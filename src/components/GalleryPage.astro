---
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { t } from '../i18n/translations';
import { filterByLocale, getContentUrl } from '../i18n/content';
import type { Locale } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const allArtworks = await getCollection('artworks');
const artworks = filterByLocale(allArtworks, locale);

const masters = [...new Set(artworks.map(a => a.data.master))].sort();
const decades = [...new Set(artworks.map(a => a.data.decade).filter(Boolean))].sort();
const subjects = [...new Set(artworks.flatMap(a => a.data.subject || []))].sort();

const pageTitle = t(locale, 'gallery.title');
const pageSubtitle = t(locale, 'gallery.subtitle');
const filterMaster = t(locale, 'gallery.master');
const filterDecade = t(locale, 'gallery.decade');
const filterSubject = t(locale, 'gallery.subject');
const loadMoreText = t(locale, 'gallery.loadMore');
const noResultsText = t(locale, 'gallery.noResults');
const galleryBase = locale === 'en' ? '/en/gallery' : '/gallery';
---
<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={pageTitle} description={pageSubtitle} />
    <style is:global>
      .gallery-page main { max-width: 960px; width: 960px; }
      h1.gallery-title { font-size: 2rem; margin-bottom: 0.25rem; }
      .subtitle { color: rgb(96, 115, 159); font-size: 1.05rem; margin-bottom: 2rem; }

      .filters { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgb(229, 233, 240); }
      .filter-group { position: relative; }
      .filter-toggle {
        display: flex; align-items: center; gap: 0.4em;
        padding: 0.5rem 1rem; border-radius: 50px;
        border: 1px solid rgb(229, 233, 240); background: white;
        cursor: pointer; font-family: inherit; font-size: 0.9rem;
        color: rgb(55, 65, 81); transition: all 0.2s;
      }
      .filter-toggle:hover { border-color: #c0392b; color: #c0392b; }
      .filter-toggle.has-value { background: #fff0ee; border-color: #f5c6c0; color: #c0392b; }
      .filter-chevron { transition: transform 0.2s; color: rgb(156, 163, 175); }
      .filter-group.open .filter-chevron { transform: rotate(180deg); }
      .filter-menu {
        display: none; position: absolute; top: calc(100% + 6px); left: 0;
        background: white; border: 1px solid rgb(229, 233, 240); border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1); overflow: hidden;
        min-width: 220px; max-height: 300px; overflow-y: auto; z-index: 50;
      }
      .filter-group.open .filter-menu { display: block; }
      .filter-option {
        display: flex; align-items: center; gap: 0.5em;
        padding: 0.55rem 1rem; font-size: 0.88rem;
        color: rgb(55, 65, 81); cursor: pointer; transition: background 0.15s;
        border: none; background: none; width: 100%; text-align: left; font-family: inherit;
      }
      .filter-option:hover { background: rgb(249, 250, 252); }
      .filter-option.selected { color: #c0392b; background: #fff0ee; font-weight: 500; }
      .filter-option + .filter-option { border-top: 1px solid rgb(243, 244, 246); }
      .filter-check {
        width: 16px; height: 16px; border-radius: 4px;
        border: 1.5px solid rgb(209, 213, 219); flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.15s;
      }
      .filter-option.selected .filter-check {
        background: #c0392b; border-color: #c0392b;
      }
      .filter-check-icon { display: none; }
      .filter-option.selected .filter-check-icon { display: block; }

      .active-filters { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem; }
      .active-filters:empty { margin-bottom: 0; }
      .filter-tag {
        display: inline-block;
        background: #fff0ee;
        padding: 2px 10px;
        border-radius: 12px;
        margin: 2px;
        text-decoration: none;
        color: #c0392b;
        border: 1px solid #f5c6c0;
        font-size: 0.85rem;
        cursor: pointer;
        font-family: inherit;
        transition: all 0.2s;
      }
      .filter-tag:hover {
        background: #c0392b;
        color: white;
        border-color: #c0392b;
      }
      .filter-clear {
        display: inline-block;
        background: #f0f0f0;
        padding: 2px 10px;
        border-radius: 12px;
        margin: 2px;
        color: inherit;
        border: 1px solid rgb(229, 233, 240);
        font-size: 0.85rem;
        cursor: pointer;
        font-family: inherit;
        transition: all 0.2s;
      }
      .filter-clear:hover { border-color: #c0392b; color: #c0392b; }

      .gallery-grid {
        display: grid; grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
      }
      .artwork-card {
        text-decoration: none; color: inherit; display: block;
        transition: transform 0.2s;
      }
      .artwork-card:hover { transform: translateY(-4px); }
      .artwork-card[hidden] { display: none; }
      .artwork-img {
        width: 100%; height: auto; object-fit: contain;
        display: block; background: rgb(229, 233, 240);
        border-radius: 0;
      }
      .artwork-info { padding: 0.6rem 0; }
      .artwork-master { font-size: 0.88rem; font-weight: 700; margin: 0; line-height: 1.3; }
      .artwork-title { font-size: 0.82rem; font-style: italic; color: rgb(96, 115, 159); margin: 0.1rem 0 0; }
      .artwork-year { font-size: 0.78rem; color: rgb(96, 115, 159); margin: 0.1rem 0 0; }

      .pagination-wrap { text-align: center; margin-top: 3rem; }
      .load-more-btn {
        padding: 0.7rem 2.5rem; border-radius: 50px; font-size: 0.95rem;
        border: 1px solid rgb(229, 233, 240); background: white;
        cursor: pointer; font-family: inherit; color: rgb(55, 65, 81);
        transition: all 0.2s;
      }
      .load-more-btn:hover { border-color: #c0392b; color: #c0392b; }
      .load-more-btn[hidden] { display: none; }
      .page-indicator {
        margin-top: 1rem; font-size: 0.85rem; color: rgb(156, 163, 175);
        letter-spacing: 0.15em;
      }
      .no-results {
        text-align: center; color: rgb(96, 115, 159);
        padding: 4rem 0; font-size: 1rem;
      }
      .no-results[hidden] { display: none; }

      @media (max-width: 960px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
      @media (max-width: 600px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
    </style>
  </head>
  <body class="gallery-page">
    <Header />
    <main>
      <h1>{pageTitle}</h1>
      <p class="subtitle">{pageSubtitle}</p>

      <div class="filters" id="filters">
        <div class="filter-group" data-filter="master">
          <button class="filter-toggle" type="button">
            {filterMaster}
            <svg class="filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="filter-menu">
            {masters.map(m => (
              <button class="filter-option" data-value={m} type="button">
                <span class="filter-check">
                  <svg class="filter-check-icon" width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                {m}
              </button>
            ))}
          </div>
        </div>

        <div class="filter-group" data-filter="decade">
          <button class="filter-toggle" type="button">
            {filterDecade}
            <svg class="filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="filter-menu">
            {decades.map(d => (
              <button class="filter-option" data-value={d} type="button">
                <span class="filter-check">
                  <svg class="filter-check-icon" width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                {d}
              </button>
            ))}
          </div>
        </div>

        <div class="filter-group" data-filter="subject">
          <button class="filter-toggle" type="button">
            {filterSubject}
            <svg class="filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="filter-menu">
            {subjects.map(s => (
              <button class="filter-option" data-value={s} type="button">
                <span class="filter-check">
                  <svg class="filter-check-icon" width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                {s}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="active-filters" id="active-filters"></div>

      <div class="gallery-grid" id="gallery-grid">
        {artworks.map(artwork => (
          <a
            href={getContentUrl('gallery', artwork.id)}
            class="artwork-card"
            data-master={artwork.data.master}
            data-decade={artwork.data.decade || ''}
            data-subject={JSON.stringify(artwork.data.subject || [])}
          >
            <Image
              src={artwork.data.image}
              alt={artwork.data.title}
              widths={[300, 400]}
              sizes="(max-width: 600px) 50vw, 25vw"
              class="artwork-img"
            />
            <div class="artwork-info">
              <p class="artwork-master">{artwork.data.master}</p>
              <p class="artwork-title">{artwork.data.title}</p>
              {artwork.data.year && <p class="artwork-year">{artwork.data.year}</p>}
            </div>
          </a>
        ))}
      </div>

      <p class="no-results" id="no-results" hidden>{noResultsText}</p>

      <div class="pagination-wrap">
        <button class="load-more-btn" id="load-more" type="button">{loadMoreText}</button>
        <div class="page-indicator" id="page-indicator"></div>
      </div>
    </main>
    <Footer />

    <script is:inline define:vars={{ galleryBase }}>
    (function() {
      const PER_PAGE = 20;
      let shown = PER_PAGE;
      const cards = Array.from(document.querySelectorAll('.artwork-card'));
      const loadMoreBtn = document.getElementById('load-more');
      const pageIndicator = document.getElementById('page-indicator');
      const noResults = document.getElementById('no-results');
      const activeFiltersWrap = document.getElementById('active-filters');

      // Multi-select filters: each key holds an array
      const filters = { master: [], decade: [], subject: [] };

      // Read filters from URL on load
      const params = new URLSearchParams(window.location.search);
      ['master', 'decade', 'subject'].forEach(key => {
        const val = params.get(key);
        if (val) {
          filters[key] = val.split(',');
          const group = document.querySelector('[data-filter="' + key + '"]');
          if (group) {
            group.querySelector('.filter-toggle').classList.add('has-value');
            filters[key].forEach(v => {
              const opt = group.querySelector('[data-value="' + v + '"]');
              if (opt) opt.classList.add('selected');
            });
          }
        }
      });

      // Dropdown toggle
      document.querySelectorAll('.filter-group').forEach(group => {
        const toggle = group.querySelector('.filter-toggle');
        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const wasOpen = group.classList.contains('open');
          document.querySelectorAll('.filter-group').forEach(g => g.classList.remove('open'));
          if (!wasOpen) group.classList.add('open');
        });

        // Prevent menu close on click inside
        group.querySelector('.filter-menu').addEventListener('click', (e) => {
          e.stopPropagation();
        });

        group.querySelectorAll('.filter-option').forEach(opt => {
          opt.addEventListener('click', () => {
            const filterKey = group.dataset.filter;
            const value = opt.dataset.value;
            const idx = filters[filterKey].indexOf(value);

            if (idx > -1) {
              filters[filterKey].splice(idx, 1);
              opt.classList.remove('selected');
            } else {
              filters[filterKey].push(value);
              opt.classList.add('selected');
            }

            toggle.classList.toggle('has-value', filters[filterKey].length > 0);
            shown = PER_PAGE;
            updateUrl();
            applyFilters();
          });
        });
      });

      document.addEventListener('click', () => {
        document.querySelectorAll('.filter-group').forEach(g => g.classList.remove('open'));
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') document.querySelectorAll('.filter-group').forEach(g => g.classList.remove('open'));
      });

      function updateUrl() {
        const p = new URLSearchParams();
        Object.entries(filters).forEach(([key, values]) => {
          if (values.length > 0) p.set(key, values.join(','));
        });
        const qs = p.toString();
        const newUrl = galleryBase + (qs ? '?' + qs : '');
        history.replaceState(null, '', newUrl);

        // Update all card links to include current filters
        cards.forEach(card => {
          const base = card.getAttribute('href').split('?')[0];
          card.setAttribute('href', base + (qs ? '?from=' + encodeURIComponent(qs) : ''));
        });
      }

      function applyFilters() {
        let visibleCount = 0;
        let totalMatching = 0;

        cards.forEach(card => {
          let match = true;
          if (filters.master.length > 0 && !filters.master.includes(card.dataset.master)) match = false;
          if (filters.decade.length > 0 && !filters.decade.includes(card.dataset.decade)) match = false;
          if (filters.subject.length > 0) {
            const cardSubjects = JSON.parse(card.dataset.subject || '[]');
            if (!filters.subject.some(s => cardSubjects.includes(s))) match = false;
          }

          if (match) {
            totalMatching++;
            if (totalMatching <= shown) {
              card.hidden = false;
              visibleCount++;
            } else {
              card.hidden = true;
            }
          } else {
            card.hidden = true;
          }
        });

        noResults.hidden = totalMatching > 0;
        loadMoreBtn.hidden = visibleCount >= totalMatching;
        pageIndicator.textContent = totalMatching > 0
          ? visibleCount + ' / ' + totalMatching
          : '';

        renderActiveTags();
      }

      function renderActiveTags() {
        activeFiltersWrap.innerHTML = '';
        let hasAny = false;
        Object.entries(filters).forEach(([key, values]) => {
          values.forEach(value => {
            hasAny = true;
            const tag = document.createElement('button');
            tag.className = 'filter-tag';
            tag.textContent = value + ' ×';
            tag.addEventListener('click', () => {
              const idx = filters[key].indexOf(value);
              if (idx > -1) filters[key].splice(idx, 1);
              const group = document.querySelector('[data-filter="' + key + '"]');
              const opt = group.querySelector('[data-value="' + value + '"]');
              if (opt) opt.classList.remove('selected');
              group.querySelector('.filter-toggle').classList.toggle('has-value', filters[key].length > 0);
              shown = PER_PAGE;
              updateUrl();
              applyFilters();
            });
            activeFiltersWrap.appendChild(tag);
          });
        });
        if (hasAny) {
          const clearBtn = document.createElement('button');
          clearBtn.className = 'filter-clear';
          clearBtn.textContent = '✕ Скинути';
          clearBtn.addEventListener('click', () => {
            Object.keys(filters).forEach(k => { filters[k] = []; });
            document.querySelectorAll('.filter-option').forEach(o => o.classList.remove('selected'));
            document.querySelectorAll('.filter-toggle').forEach(t => t.classList.remove('has-value'));
            shown = PER_PAGE;
            updateUrl();
            applyFilters();
          });
          activeFiltersWrap.appendChild(clearBtn);
        }
      }

      loadMoreBtn.addEventListener('click', () => {
        shown += PER_PAGE;
        applyFilters();
      });

      applyFilters();
      updateUrl();
    })();
    </script>
  </body>
</html>