---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getLocaleFromUrl } from '../i18n/translations';
import { filterByLocale, getContentUrl } from '../i18n/content';

const locale = getLocaleFromUrl(Astro.url);

const masters   = filterByLocale(await getCollection('masters'), locale);
const books     = filterByLocale(await getCollection('books'), locale);
const materials = filterByLocale(await getCollection('materials'), locale);

const allItems = [
  ...masters.map(m => ({
    title: m.data.name,
    subtitle: m.data.category,
    url: getContentUrl('masters', m.id),
    image: m.data.photo ?? null,
    badge: m.data.category === 'Дослідники петриківського розпису'
      ? (locale === 'en' ? 'Researcher' : 'Дослідник')
      : (locale === 'en' ? 'Master' : 'Майстер'),
    icon: '🎨',
  })),
  ...books.map(b => ({
    title: b.data.title,
    subtitle: b.data.author ?? null,
    url: getContentUrl('books', b.id),
    image: b.data.cover ?? null,
    badge: b.data.category || (locale === 'en' ? 'Book' : 'Книга'),
    icon: '📖',
  })),
  ...materials.map(m => ({
    title: m.data.title,
    subtitle: m.data.description ?? null,
    url: getContentUrl('materials', m.id),
    image: m.data.cover ?? null,
    badge: m.data.category,
    icon: m.data.category === 'Відео' ? '▶️' : m.data.category === 'Галереї' ? '🖼️' : '📄',
  })),
];

const heading = locale === 'en'
  ? 'Interesting materials about Petrykivka painting'
  : 'Цікаві матеріали про петриківський розпис';
---

<section class="fc-section">
  <h2 class="fc-heading">{heading}</h2>

  <div class="fc-wrapper">
    <button class="fc-btn fc-btn--prev" aria-label={locale === 'en' ? 'Previous' : 'Назад'}>
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
        <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="fc-viewport">
      <div class="fc-track">
        {allItems.map(item => (
          <a href={item.url} class="fc-card">
            <div class="fc-card__img-wrap">
              {item.image ? (
                <Image src={item.image} alt={item.title} width={280} height={190} class="fc-card__img" />
              ) : (
                <div class="fc-card__placeholder">{item.icon}</div>
              )}
              <span class="fc-card__badge">{item.badge}</span>
            </div>
            <div class="fc-card__body">
              <p class="fc-card__title">{item.title}</p>
              {item.subtitle && <p class="fc-card__sub">{item.subtitle}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>

    <button class="fc-btn fc-btn--next" aria-label={locale === 'en' ? 'Next' : 'Вперед'}>
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
        <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <div class="fc-dots"></div>
</section>

<style is:global>
  .fc-section { margin-top: 3rem; padding-top: 3rem; border-top: 1px solid rgb(229, 233, 240); }
  .fc-heading { font-size: 1.4rem; font-weight: 700; text-align: center; margin: 0 0 1.5rem; color: rgb(15, 18, 25); font-family: "Fixel", sans-serif; }
  .fc-wrapper { position: relative; display: flex; align-items: center; width: 100vw; left: 50%; margin-left: -50vw; }
  .fc-viewport { flex: 1; overflow: hidden; min-width: 0; }
  .fc-track { display: flex; gap: 1rem; padding: 1rem 3.5rem 2rem; transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); will-change: transform; cursor: grab; user-select: none; }
  .fc-track.is-dragging { cursor: grabbing; transition: none; }
  .fc-card { flex: 0 0 240px; border-radius: 12px; overflow: hidden; border: 1px solid rgb(229, 233, 240); text-decoration: none; color: inherit; display: flex; flex-direction: column; background: #fff; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; }
  .fc-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); border-color: transparent; }
  .fc-card__img-wrap { position: relative; width: 100%; height: 170px; overflow: hidden; background: rgb(229, 233, 240); flex-shrink: 0; }
  .fc-card__img { width: 100%; height: 170px; object-fit: cover; display: block; border-radius: 0; }
  .fc-card__placeholder { width: 100%; height: 170px; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; background: rgb(229, 233, 240); }
  .fc-card__badge { position: absolute; top: 0.5rem; left: 0.5rem; background: rgba(255,255,255,0.93); color: #c0392b; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2rem 0.55rem; border-radius: 20px; border: 1px solid rgba(192,57,43,0.18); font-family: "Fixel", sans-serif; white-space: nowrap; }
  .fc-card__body { padding: 0.85rem 1rem 1rem; flex: 1; display: flex; flex-direction: column; gap: 0.25rem; }
  .fc-card__title { font-size: 0.92rem; font-weight: 700; margin: 0; line-height: 1.3; color: rgb(15, 18, 25); font-family: "Fixel", sans-serif; }
  .fc-card__sub { font-size: 0.78rem; color: rgb(96, 115, 159); margin: 0; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-family: "Fixel", sans-serif; }
  .fc-btn { position: absolute; top: 50%; transform: translateY(-50%); z-index: 3; width: 36px; height: 36px; border-radius: 50%; border: 1px solid rgb(229, 233, 240); background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; color: rgb(15, 18, 25); transition: border-color 0.2s, color 0.2s, box-shadow 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.08); padding: 0; }
  .fc-btn:hover { border-color: #c0392b; color: #c0392b; box-shadow: 0 4px 12px rgba(192,57,43,0.15); }
  .fc-btn:disabled { opacity: 0.25; cursor: default; pointer-events: none; }
  .fc-btn--prev { left: 0.75rem; }
  .fc-btn--next { right: 0.75rem; }
  .fc-dots { display: flex; justify-content: center; gap: 0.4rem; margin-top: 1.25rem; padding-bottom: 0.5rem; }
  .fc-dot { width: 6px; height: 6px; border-radius: 50%; background: rgb(229, 233, 240); border: none; padding: 0; cursor: pointer; transition: background 0.2s, transform 0.2s; }
  .fc-dot.active { background: #c0392b; transform: scale(1.4); }
  @media (max-width: 720px) { .fc-card { flex: 0 0 200px; } .fc-track { padding: 0.5rem 2.5rem; } .fc-btn--prev { left: 0.25rem; } .fc-btn--next { right: 0.25rem; } }
</style>

<script is:inline>
(function () {
  const section = document.querySelector('.fc-section');
  if (!section) return;
  const track = section.querySelector('.fc-track');
  const viewport = section.querySelector('.fc-viewport');
  const btnPrev = section.querySelector('.fc-btn--prev');
  const btnNext = section.querySelector('.fc-btn--next');
  const dotsWrap = section.querySelector('.fc-dots');
  const allCards = Array.from(track.querySelectorAll('.fc-card'));
  const SHOW = 8;
  const shuffled = allCards.slice().sort(() => Math.random() - 0.5).slice(0, SHOW);
  allCards.forEach(c => c.remove());
  shuffled.forEach(c => track.appendChild(c));
  const cards = Array.from(track.querySelectorAll('.fc-card'));
  const count = cards.length;
  let current = 0, startX = 0;
  function cardW() { const gap = parseFloat(window.getComputedStyle(track).gap) || 16; return (cards[0]?.getBoundingClientRect().width || 240) + gap; }
  function visibleCount() { return Math.max(1, Math.floor(viewport.getBoundingClientRect().width / cardW())); }
  function maxIdx() { return Math.max(0, count - visibleCount()); }
  cards.forEach((_, i) => { const d = document.createElement('button'); d.className = 'fc-dot' + (i === 0 ? ' active' : ''); d.addEventListener('click', () => goTo(i)); dotsWrap.appendChild(d); });
  const dots = Array.from(dotsWrap.querySelectorAll('.fc-dot'));
  function goTo(idx) { current = Math.max(0, Math.min(idx, maxIdx())); track.style.transform = 'translateX(-' + (current * cardW()) + 'px)'; dots.forEach((d, i) => d.classList.toggle('active', i === current)); btnPrev.disabled = current === 0; btnNext.disabled = current >= maxIdx(); }
  btnPrev.addEventListener('click', () => goTo(current - 1));
  btnNext.addEventListener('click', () => goTo(current + 1));
  let dragging = false, startTranslate = 0;
  function getTranslate() { const m = (track.style.transform || '').match(/-?([\d.]+)px/); return m ? -parseFloat(m[0]) : 0; }
  track.addEventListener('mousedown', e => { dragging = true; startX = e.clientX; startTranslate = getTranslate(); track.classList.add('is-dragging'); });
  window.addEventListener('mousemove', e => { if (!dragging) return; track.style.transform = 'translateX(' + (startTranslate + e.clientX - startX) + 'px)'; });
  window.addEventListener('mouseup', e => { if (!dragging) return; dragging = false; track.classList.remove('is-dragging'); const diff = e.clientX - startX; goTo(Math.abs(diff) > 50 ? (diff < 0 ? current + 1 : current - 1) : current); });
  track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; track.style.transition = 'none'; }, { passive: true });
  track.addEventListener('touchend', e => { track.style.transition = ''; const diff = e.changedTouches[0].clientX - startX; goTo(Math.abs(diff) > 40 ? (diff < 0 ? current + 1 : current - 1) : current); });
  cards.forEach(card => { card.addEventListener('click', e => { if (Math.abs(e.clientX - startX) > 6) e.preventDefault(); }); });
  window.addEventListener('resize', () => goTo(current));
  goTo(0);
})();
</script>