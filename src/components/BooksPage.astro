---
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { t } from '../i18n/translations';
import { filterByLocale, getContentUrl } from '../i18n/content';
import type { Locale } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const allBooks = await getCollection('books');
const books = filterByLocale(allBooks, locale);

const categories = [
  'Альбоми',
  'Альбоми про майстрів',
  'Мистецтвознавчі дослідження',
  'Оздоблені розписом',
  'Наукові статті',
  'Інше',
];

const categoryNamesEn: Record<string, string> = {
  'Альбоми': 'Albums',
  'Альбоми про майстрів': 'Albums about Masters',
  'Мистецтвознавчі дослідження': 'Art Studies',
  'Оздоблені розписом': 'Decorated with Painting',
  'Наукові статті': 'Scientific Articles',
  'Інше': 'Other',
};

const booksByCategory = categories.map(category => ({
  category,
  displayName: locale === 'en' ? (categoryNamesEn[category] || category) : category,
  books: books.filter(b => b.data.category === category),
})).filter(group => group.books.length > 0);

const readOnlineLabel = locale === 'uk' ? 'Читати онлайн' : 'Read online';

// --- Таб-перемикач "Обрані видання | Реєстр публікацій" ---
const booksUrl = locale === 'en' ? '/en/books' : '/books';
const registryUrl = locale === 'en' ? '/en/publications' : '/publications';
const tabBooksLabel = locale === 'uk' ? 'Обрані видання' : 'Featured books';
const tabRegistryLabel = locale === 'uk' ? 'Реєстр публікацій' : 'Publications registry';
---
<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={t(locale, 'nav.books')} description={t(locale, 'nav.books')} />
    <style>
      .books-page main {
       max-width: 960px;
       width: 100%;
       margin: 0 auto;
       padding: 1rem;
       box-sizing: border-box;
     }
      h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
      .subtitle { color: rgb(96, 115, 159); font-size: 1.1rem; margin-bottom: 1.5rem; }

      .books-tabs { display: flex; gap: 0.5rem; margin-bottom: 2rem; border-bottom: 1px solid rgb(229, 233, 240); }
      .books-tabs a {
        text-decoration: none; padding: 0.6rem 0.2rem; margin-right: 1.5rem;
        color: rgb(96, 115, 159); font-size: 1rem; font-weight: 600;
        border-bottom: 2px solid transparent; transition: color 0.2s, border-color 0.2s;
      }
      .books-tabs a:hover { color: #c0392b; }
      .books-tabs a.active { color: #c0392b; border-bottom-color: #c0392b; }

      .nav-anchors { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 3rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgb(229, 233, 240); }
      .nav-anchors a { text-decoration: none; padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid rgb(229, 233, 240); color: rgb(0, 0, 0); transition: all 0.2s; }
      .nav-anchors a:hover { border-color: #c0392b; color: #c0392b; }
      .category-section { margin-bottom: 4rem; }
      .category-section h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 1.5rem; padding-bottom: 0.75rem; border-bottom: 2px solid #c0392b; display: inline-block; }

      .books-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        column-gap: 1.5rem;
        row-gap: 0;
      }
      .book-card {
        text-decoration: none; color: inherit; display: block;
        transition: transform 0.2s;
        padding-top: 1.5rem; padding-bottom: 0.5rem;
      }
      .book-card:hover { transform: translateY(-4px); }
      .book-cover {
        width: 100%; height: auto; object-fit: contain;
        display: block; background: rgb(229, 233, 240);
        border-radius: 0;
      }
      .book-cover-placeholder {
        width: 100%; aspect-ratio: 3 / 4; background: rgb(229, 233, 240);
        display: flex; align-items: center; justify-content: center; font-size: 3rem;
      }
      .book-info { padding: 0.6rem 0 0; }
      .book-title { font-size: 0.88rem; font-weight: 700; margin: 0; line-height: 1.3; }
      .book-author { font-size: 0.82rem; font-style: italic; color: rgb(96, 115, 159); margin: 0.1rem 0 0; }
      .book-year { font-size: 0.78rem; color: rgb(96, 115, 159); margin: 0.1rem 0 0; }
      .book-links { margin-top: 0.35rem; }
      .book-link {
        font-size: 0.78rem; color: #c0392b; text-decoration: none;
      }
      .book-link:hover { text-decoration: underline; }
      .book-link + .book-link::before { content: '·'; margin: 0 0.4em; color: rgb(156, 163, 175); }

      /* Лінії-«полиці» між рядками, рахуємо по колонках на кожен брейкпоінт */
      .book-card:nth-child(-n+4) { border-top: none; padding-top: 0; }
      .book-card:nth-child(n+5) { border-top: 1px solid rgb(229, 233, 240); }

      @media (max-width: 960px) {
        .books-grid { grid-template-columns: repeat(3, 1fr); }
        .book-card { border-top: none; padding-top: 1.5rem; }
        .book-card:nth-child(-n+3) { border-top: none; padding-top: 0; }
        .book-card:nth-child(n+4) { border-top: 1px solid rgb(229, 233, 240); }
      }
      @media (max-width: 700px) {
        .books-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
        .book-card { border-top: none; padding-top: 1.5rem; }
        .book-card:nth-child(-n+2) { border-top: none; padding-top: 0; }
        .book-card:nth-child(n+3) { border-top: 1px solid rgb(229, 233, 240); }
      }
      @media (max-width: 520px) {
        .books-grid { grid-template-columns: 1fr; gap: 1.25rem; }
        .book-card { border-top: none; padding-top: 1.5rem; }
        .book-card:nth-child(1) { border-top: none; padding-top: 0; }
        .book-card:nth-child(n+2) { border-top: 1px solid rgb(229, 233, 240); }
      }
    </style>
 </head>
  <body class="books-page">
    <Header />
    <main>
      <h1>{t(locale, 'nav.books')}</h1>
      <p class="subtitle">
        {locale === 'uk'
          ? 'Бібліотека видань про петриківський розпис'
          : 'Library of publications about Petrykivka painting'}
      </p>

      <nav class="books-tabs">
        <a href={booksUrl} class="active">{tabBooksLabel}</a>
        <a href={registryUrl}>{tabRegistryLabel}</a>
      </nav>

      <nav class="nav-anchors">
        {booksByCategory.map(group => (
          <a href={'#' + group.displayName.toLowerCase().replace(/ /g, '-')}>
            {group.displayName}
          </a>
        ))}
      </nav>

      {booksByCategory.map(group => (
        <section class="category-section" id={group.displayName.toLowerCase().replace(/ /g, '-')}>
          <h2>{group.displayName}</h2>
          <div class="books-grid">
            {group.books.map(book => (
              <a href={getContentUrl('books', book.id)} class="book-card">
                {book.data.cover
                  ? <Image src={book.data.cover} alt={book.data.title} widths={[200, 300]} sizes="(max-width: 700px) 50vw, 25vw" class="book-cover" />
                  : <div class="book-cover-placeholder">📖</div>
                }
                <div class="book-info">
                  <p class="book-title">{book.data.title}</p>
                  {book.data.author && <p class="book-author">{book.data.author}</p>}
                  {book.data.year && <p class="book-year">{book.data.year}</p>}
                  <div class="book-links">
                    {book.data.externalUrl && <span class="book-link">{readOnlineLabel}</span>}
                    {book.data.pdfUrl && <span class="book-link">PDF</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>
    <Footer />
  </body>
</html>