---
const { name, url, description } = Astro.props;
---
<a href={url} class="learnmore-block">
  <span class="learnmore-label">Дізнайтесь більше</span>
  <span class="learnmore-name">{name}</span>
  {description && <span class="learnmore-desc">{description}</span>}
  <span class="learnmore-arrow">→</span>
</a>

<style is:global>
  .learnmore-block {
    display: block;
    margin: 2rem 0;
    padding: 1.2rem 1.5rem;
    background: #fff8f7;
    border: 1px solid #f5c6c0;
    border-left: 4px solid #c0392b;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    position: relative;
  }
  .learnmore-block:hover {
    background: #fff0ee;
  }
  .learnmore-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #c0392b;
    margin-bottom: 0.3rem;
  }
  .learnmore-name {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: inherit;
  }
  .learnmore-desc {
    display: block;
    font-size: 0.9rem;
    color: rgb(96, 115, 159);
  }
  .learnmore-arrow {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.3rem;
    color: #c0392b;
  }
</style>