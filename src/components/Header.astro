---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <button class="burger" id="burger" aria-label="Меню">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="internal-links" id="nav-links">
      <HeaderLink href="/masters">Майстри</HeaderLink>
      <HeaderLink href="/blog">Блог</HeaderLink>
      <HeaderLink href="/books">Книги</HeaderLink>
      <HeaderLink href="/materials">Матеріали</HeaderLink>
      <HeaderLink href="/about">Про проект</HeaderLink>
	  <a href="/search" aria-label="Пошук" class="search-icon">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
</a>
    </div>
  </nav>
</header>

<style is:global>
  header {
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 2px 8px rgba(15, 18, 25, 0.05);
    position: sticky;
    top: 0;
    z-index: 100;
	header .search-icon {
  display: flex;
  align-items: center;
  padding: 0.5em 0.6em;
  border-bottom: 4px solid transparent !important;
}
header .search-icon:hover {
  opacity: 0.7;
}
  }
  header h2 {
    margin: 0;
    font-size: 1em;
  }
  header h2 a {
    text-decoration: none;
    color: rgb(15, 18, 25);
  }
  header nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: nowrap;
    min-height: 60px;
  }
  header .internal-links {
    display: flex;
    align-items: center;
    gap: 0.25em;
  }
  header nav a {
    padding: 0.5em 0.6em;
    color: rgb(15, 18, 25);
    border-bottom: 4px solid transparent;
    text-decoration: none;
    font-size: 0.95em;
    white-space: nowrap;
  }
  header nav a.active {
    border-bottom-color: #c0392b;
  }
  header .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5em;
  }
  header .burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: rgb(15, 18, 25);
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    header .burger {
      display: flex;
    }
    header .internal-links {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: white;
      flex-direction: column;
      align-items: flex-start;
      padding: 1em;
      box-shadow: 0 4px 8px rgba(15, 18, 25, 0.1);
      gap: 0;
    }
    header .internal-links.open {
      display: flex;
    }
    header nav a {
      width: 100%;
      padding: 0.75em 0.5em;
      border-bottom: 1px solid rgb(229, 233, 240);
      border-top: none;
      border-left: none;
      border-right: none;
    }
    header nav a.active {
      border-bottom: 1px solid rgb(229, 233, 240);
      color: #c0392b;
    }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('nav-links');

  burger?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
  });

  document.querySelectorAll('.internal-links a').forEach(link => {
    link.addEventListener('click', () => {
      navLinks?.classList.remove('open');
    });
  });
</script>