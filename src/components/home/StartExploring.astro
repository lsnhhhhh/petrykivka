---
import HomepageSection from './HomepageSection.astro';
import { getCollection } from 'astro:content';
import { sectionTitles, startExploring } from '../../data/homepage';

interface Props {
  locale: 'uk' | 'en';
}

const { locale } = Astro.props;

const allMasters = await getCollection('masters');
const allMaterials = await getCollection('materials');

const masters = allMasters.filter((m) => m.data.locale === locale);
const materials = allMaterials.filter((m) => m.data.locale === locale);

// Витягнути чистий slug з id (працює для 'uk/tetyana-pata' і для 'tetyana-pata')
function getSlugOnly(id: string) {
  return id.includes('/') ? id.split('/').pop()! : id;
}

function findBySlug(collection: any[], slug: string) {
  return collection.find((item) => getSlugOnly(item.id) === slug);
}

const masterCards = startExploring.masters.slugs
  .map((slug) => findBySlug(masters, slug))
  .filter(Boolean);

const historyCards = startExploring.history.slugs
  .map((slug) => findBySlug(materials, slug))
  .filter(Boolean);

const workshopCards = startExploring.workshops.slugs
  .map((slug) => findBySlug(materials, slug))
  .filter(Boolean);

function masterUrl(slug: string) {
  return locale === 'uk' ? `/masters/${slug}` : `/en/masters/${slug}`;
}
function materialUrl(slug: string) {
  return locale === 'uk' ? `/materials/${slug}` : `/en/materials/${slug}`;
}

function getMasterPeriod(master: any) {
  const born = master.data.born;
  const died = master.data.died;
  const byear = born ? String(born).slice(0, 4) : '';
  const dyear = died ? String(died).slice(0, 4) : '';
  if (byear && dyear) return `${byear}–${dyear}`;
  if (byear) return `від ${byear}`;
  return '';
}

const placeholderText = {
  uk: 'Більше матеріалів незабаром',
  en: 'More materials coming soon',
};

// Скільки заглушок треба у кожному стовпці (до 3 загалом)
const needPlaceholder = (cards: any[]) => cards.length < 3 ? 1 : 0;
---

<HomepageSection
  title={sectionTitles.startExploring[locale]}
  background="cream"
>
  <div class="explore">
    <!-- Колонка 1: Майстри -->
    <div class="explore__column">
      <p class="explore__col-title">{startExploring.masters.title[locale]}</p>
      <div class="explore__cards">
        {masterCards.map((master) => (
          <a href={masterUrl(getSlugOnly(master.id))} class="explore__card">
            <div class="explore__card-content">
              <h3 class="explore__card-title">{master.data.name}</h3>
              {getMasterPeriod(master) && (
                <div class="explore__card-meta">{getMasterPeriod(master)}</div>
              )}
            </div>
            <svg class="explore__card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        ))}
        {Array.from({ length: needPlaceholder(masterCards) }).map(() => (
          <div class="explore__card explore__card--placeholder">
            <span>{placeholderText[locale]}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Колонка 2: Історія -->
    <div class="explore__column">
      <p class="explore__col-title">{startExploring.history.title[locale]}</p>
      <div class="explore__cards">
        {historyCards.map((material) => (
          <a href={materialUrl(getSlugOnly(material.id))} class="explore__card">
            <div class="explore__card-content">
              <h3 class="explore__card-title">{material.data.title}</h3>
              {material.data.description && (
                <p class="explore__card-desc">{material.data.description}</p>
              )}
            </div>
            <svg class="explore__card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        ))}
        {Array.from({ length: needPlaceholder(historyCards) }).map(() => (
          <div class="explore__card explore__card--placeholder">
            <span>{placeholderText[locale]}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Колонка 3: Навчання -->
    <div class="explore__column">
      <p class="explore__col-title">{startExploring.workshops.title[locale]}</p>
      <div class="explore__cards">
        {workshopCards.map((material) => (
          <a href={materialUrl(getSlugOnly(material.id))} class="explore__card">
            <div class="explore__card-content">
              <h3 class="explore__card-title">{material.data.title}</h3>
              {material.data.description && (
                <p class="explore__card-desc">{material.data.description}</p>
              )}
            </div>
            <svg class="explore__card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        ))}
        {Array.from({ length: needPlaceholder(workshopCards) }).map(() => (
          <div class="explore__card explore__card--placeholder">
            <span>{placeholderText[locale]}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</HomepageSection>

<style>
  .explore {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .explore__column {
    display: flex;
    flex-direction: column;
  }
  .explore__col-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(40, 42, 43, 0.55);
    margin: 0 0 16px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .explore__cards {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .explore__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 18px 20px;
    background: #fff;
    border: 1px solid rgba(40, 42, 43, 0.08);
    border-radius: 10px;
    text-decoration: none;
    color: #282A2B;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .explore__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(40, 42, 43, 0.06);
    border-color: rgba(192, 57, 43, 0.2);
  }
  .explore__card:hover .explore__card-arrow {
    color: #c0392b;
    transform: translateX(3px);
  }
  .explore__card-content {
    flex: 1;
    min-width: 0;
  }
  .explore__card-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    color: #282A2B;
  }
  .explore__card-meta {
    font-size: 0.8125rem;
    color: rgba(40, 42, 43, 0.55);
    margin-top: 4px;
  }
  .explore__card-desc {
    font-size: 0.8125rem;
    color: rgba(40, 42, 43, 0.65);
    margin: 6px 0 0;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .explore__card-arrow {
    flex-shrink: 0;
    color: rgba(40, 42, 43, 0.3);
    transition: color 0.15s ease, transform 0.15s ease;
  }
  .explore__card--placeholder {
    border: 1px dashed rgba(40, 42, 43, 0.18);
    background: transparent;
    justify-content: center;
    padding: 22px 20px;
  }
  .explore__card--placeholder span {
    font-size: 0.875rem;
    color: rgba(40, 42, 43, 0.4);
    text-align: center;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .explore {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>