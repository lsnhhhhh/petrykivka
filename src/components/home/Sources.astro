---
import HomepageSection from './HomepageSection.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { sectionTitles } from '../../data/homepage';

interface Props {
  locale: 'uk' | 'en';
}

const { locale } = Astro.props;

// Завантажуємо обкладинки книг у build-time
const bookCovers = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/books/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG}',
  { eager: true }
);

function resolveCover(img: any): ImageMetadata | null {
  if (!img) return null;
  if (typeof img !== 'string') return img as ImageMetadata;
  const absolutePath = img.replace(/^\.\.\/\.\.\/\.\.\//, '/src/');
  return bookCovers[absolutePath]?.default ?? null;
}

function getSlugOnly(id: string) {
  return id.includes('/') ? id.split('/').pop()! : id;
}

const allBooks = await getCollection('books');
const books = allBooks.filter((b) => b.data.locale === locale);

const featured = books.filter((b) => b.data.featured === true);

// Якщо є featured книги — беремо їх; якщо нема — 4 найновіші як fallback
const displayBooks = featured.length > 0
  ? featured.sort((a, b) => (a.data.featuredOrder ?? 999) - (b.data.featuredOrder ?? 999))
  : books
      .filter((b) => b.data.year)
      .sort((a, b) => Number(String(b.data.year).slice(0, 4)) - Number(String(a.data.year).slice(0, 4)))
      .slice(0, 4);

const viewAllText = locale === 'uk' ? 'Усі книги та видання' : 'All publications';
const viewAllHref = locale === 'uk' ? '/books' : '/en/books';

function bookUrl(slug: string) {
  return locale === 'uk' ? `/books/${slug}` : `/en/books/${slug}`;
}

function getInitials(title: string) {
  return title
    .split(/\s+/)
    .map((w) => w[0])
    .filter(Boolean)
    .slice(0, 2)
    .join('')
    .toUpperCase();
}
---

{displayBooks.length > 0 && (
  <HomepageSection
    title={sectionTitles.sources[locale]}
    viewAllHref={viewAllHref}
    viewAllText={viewAllText}
    background="cream"
  >
    <div class="books">
      {displayBooks.map((book) => {
        const cover = resolveCover(book.data.cover);
        const slug = getSlugOnly(book.id);
        return (
          <a href={bookUrl(slug)} class="book">
            <div class="book__cover-wrap">
              {cover ? (
                <Image
                  src={cover}
                  alt={book.data.title}
                  widths={[200, 300, 450]}
                  sizes="(max-width: 700px) 45vw, (max-width: 1000px) 30vw, 22vw"
                  class="book__cover"
                />
              ) : (
                <div class="book__cover-placeholder">
                  <span>{getInitials(book.data.title)}</span>
                </div>
              )}
            </div>
            <div class="book__info">
              <h3 class="book__title">{book.data.title}</h3>
              <div class="book__meta">
                {book.data.author && <span>{book.data.author}</span>}
                {book.data.author && book.data.year && <span class="book__sep">·</span>}
                {book.data.year && <span>{book.data.year}</span>}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </HomepageSection>
)}

<style>
  .books {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .book {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }
  .book:hover {
    transform: translateY(-3px);
  }
  .book__cover-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 6px;
    background: #E5D8C2;
    box-shadow: 0 4px 12px rgba(40, 42, 43, 0.08);
    transition: box-shadow 0.25s ease;
  }
  .book:hover .book__cover-wrap {
    box-shadow: 0 14px 32px rgba(40, 42, 43, 0.16);
  }
  .book__cover {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    border-radius: 0 !important;
    transition: transform 0.4s ease;
  }
  .book:hover .book__cover {
    transform: scale(1.03);
  }
  .book__cover-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #F0E6D6 0%, #D6C5A8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .book__cover-placeholder span {
    font-size: 3rem;
    font-weight: 400;
    color: rgba(40, 42, 43, 0.35);
    font-family: Georgia, 'Times New Roman', serif;
    letter-spacing: -0.02em;
  }
  .book__info {
    padding: 0 2px;
  }
  .book__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: #282A2B;
    line-height: 1.3;
    transition: color 0.15s ease;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .book:hover .book__title {
    color: #c0392b;
  }
  .book__meta {
    font-size: 0.8125rem;
    color: rgba(40, 42, 43, 0.6);
    line-height: 1.4;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .book__sep {
    color: rgba(40, 42, 43, 0.3);
  }

  @media (max-width: 1000px) {
    .books {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }
  @media (max-width: 700px) {
    .books {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (max-width: 420px) {
    .books {
      grid-template-columns: 1fr;
    }
  }
</style>