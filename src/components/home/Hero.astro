---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { hero, heroSlides, heroNavCards } from '../../data/homepage';

interface Props {
  locale: 'uk' | 'en';
}

const { locale } = Astro.props;

// Підрахунок матеріалів
const [masters, artworks, books, materials, centers] = await Promise.all([
  getCollection('masters'),
  getCollection('artworks'),
  getCollection('books'),
  getCollection('materials'),
  getCollection('centers'),
]);

const countByLocale = (col: any[]) =>
  col.filter((item) => item.data.locale === locale).length;

const counts: Record<string, number> = {
  masters: countByLocale(masters),
  artworks: countByLocale(artworks),
  books: countByLocale(books),
  materials: countByLocale(materials) + countByLocale(centers),
};

const icons: Record<string, string> = {
  masters: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  artworks: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  books: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  materials: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>`,
};

// Wallpaper CTA strings
const wallpaperCta = {
  badge: { uk: 'Новинка', en: 'New' },
  title: { uk: 'Створи свої шпалери', en: 'Create your own wallpaper' },
  desc: {
    uk: 'З квітів петриківського розпису — для телефону, планшета чи комп\'ютера',
    en: 'From Petrykivka painting flowers — for your phone, tablet, or computer',
  },
  action: { uk: 'Створити шпалери', en: 'Start creating' },
};
const wallpaperHref = locale === 'uk' ? '/wallpapers' : '/en/wallpapers';

const dotsLabel = locale === 'uk' ? 'Перемкнути слайд' : 'Switch slide';
const slideWord = locale === 'uk' ? 'Слайд' : 'Slide';
---

<section class="hero">
  <div class="hero__image-wrap">
    <div class="hero__slides" id="hero-slides">
      {heroSlides.map((slide, i) => (
        <a
          class="hero__slide"
          href={locale === 'uk' ? slide.hrefUk : slide.hrefEn}
          aria-label={slide.title[locale]}
          data-index={i}
        >
          <Image
            src={slide.image}
            alt={(slide.alt ?? hero.imageAlt)[locale]}
            widths={[640, 1024, 1440, 1920]}
            sizes="100vw"
            loading="eager"
            class="hero__slide-img"
          />
          <div class="hero__overlay"></div>
          <div class="hero__text">
            <p class="hero__title">{slide.title[locale]}</p>
            <p class="hero__subtitle">{slide.subtitle[locale]}</p>
            <span class="hero__slide-btn">
              {slide.buttonText[locale]}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="hero__dots" role="tablist" aria-label={dotsLabel}>
      {heroSlides.map((slide, i) => (
        <button
          type="button"
          class="hero__dot"
          data-index={i}
          aria-label={`${slideWord} ${i + 1}: ${slide.title[locale]}`}
          aria-current={i === 0 ? 'true' : 'false'}
        ></button>
      ))}
    </div>
  </div>

  <nav class="hero__nav" aria-label={locale === 'uk' ? 'Розділи енциклопедії' : 'Encyclopedia sections'}>
    <div class="hero__nav-grid">
      {heroNavCards.map((card) => (
        <a href={locale === 'uk' ? card.hrefUk : card.hrefEn} class="hero__card">
          <div class="hero__card-icon" set:html={icons[card.key]} />
          <div class="hero__card-count">{counts[card.key]}</div>
          <h3 class="hero__card-title">{card.title[locale]}</h3>
          <p class="hero__card-desc">{card.description[locale]}</p>
          <svg class="hero__card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      ))}
    </div>

    <a href={wallpaperHref} class="hero__cta">
      <div class="hero__cta-flowers" aria-hidden="true">
        <img src="/wallpaper-flowers/16-big-flower-green.png" class="hero__cta-flower hero__cta-flower--1" alt="" loading="lazy" />
        <img src="/wallpaper-flowers/18-big-flower-blue.png" class="hero__cta-flower hero__cta-flower--2" alt="" loading="lazy" />
        <img src="/wallpaper-flowers/8-medium-flower-orange.png" class="hero__cta-flower hero__cta-flower--3" alt="" loading="lazy" />
        <img src="/wallpaper-flowers/27-medium-leaf-green.png" class="hero__cta-flower hero__cta-flower--4" alt="" loading="lazy" />
      </div>
      <div class="hero__cta-body">
        <span class="hero__cta-badge">{wallpaperCta.badge[locale]}</span>
        <h3 class="hero__cta-title">{wallpaperCta.title[locale]}</h3>
        <p class="hero__cta-desc">{wallpaperCta.desc[locale]}</p>
      </div>
      <div class="hero__cta-action">
        <span class="hero__cta-action-text">{wallpaperCta.action[locale]}</span>
        <svg class="hero__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </div>
    </a>
  </nav>
</section>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.hero__slide'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.hero__dot'));
  const SLIDE_DURATION = 6000; // мс показу слайду
  const TRANSITION_MS = 1500;  // тривалість анімації переходу картинки

  if (slides.length > 1) {
    let currentIdx = 0;
    let timer: number | undefined;

    // Початковий стан: перший слайд показаний, решта внизу
    slides.forEach((slide, i) => {
      if (i === 0) {
        slide.style.transform = 'translateY(0)';
        slide.style.zIndex = '2';
      } else {
        slide.style.transform = 'translateY(100%)';
        slide.style.zIndex = '0';
      }
    });
    // Текст першого слайду з'явиться сам — через CSS-затримку класу is-visible
    slides[0].classList.add('is-visible');

    function setActiveDot(idx: number) {
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === idx);
        dot.setAttribute('aria-current', i === idx ? 'true' : 'false');
      });
    }

    function goTo(nextIdx: number) {
      if (nextIdx === currentIdx) return;
      const current = slides[currentIdx];
      const next = slides[nextIdx];

      // Ховаємо текст поточного одразу (без затримки — правило за замовчуванням)
      current.classList.remove('is-visible');
      current.style.zIndex = '1';

      // Новий слайд піднімається над попереднім
      next.style.zIndex = '2';
      next.style.transition = '';
      next.classList.remove('is-visible');
      requestAnimationFrame(() => {
        next.style.transform = 'translateY(0)';
        // Текст з'явиться сам, з CSS-затримкою (після того як картинка майже доїхала)
        next.classList.add('is-visible');
      });

      // Після завершення — попередній слайд повертається донизу (без анімації)
      setTimeout(() => {
        current.style.transition = 'none';
        current.style.transform = 'translateY(100%)';
        current.style.zIndex = '0';
      }, TRANSITION_MS + 50);

      currentIdx = nextIdx;
      setActiveDot(currentIdx);
    }

    function restartAutoplay() {
      if (timer) window.clearInterval(timer);
      timer = window.setInterval(() => {
        goTo((currentIdx + 1) % slides.length);
      }, SLIDE_DURATION + TRANSITION_MS);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.index);
        goTo(idx);
        restartAutoplay();
      });
    });

    setActiveDot(0);
    restartAutoplay();
  }
</script>

<style>
  .hero {
    background: #FFFDFB;
  }

  .hero__image-wrap {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 480px;
    max-height: 720px;
    overflow: hidden;
  }

  /* Контейнер слайдів */
  .hero__slides {
    position: absolute;
    inset: 0;
  }

  /* Кожен слайд — суцільне посилання: картинка + текст + кнопка */
  .hero__slide {
    position: absolute;
    inset: 0;
    display: block;
    transform: translateY(100%);
    transition: transform 1.5s cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
    text-decoration: none;
    color: inherit;
  }
  .hero__slide:focus-visible {
    outline: 3px solid #fff;
    outline-offset: -3px;
  }
  .hero__slide-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    object-position: center top;
    border-radius: 0 !important;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0) 45%,
      rgba(0, 0, 0, 0.15) 65%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
    transition: background 0.3s ease;
  }
  .hero__slide:hover .hero__overlay,
  .hero__slide:focus-visible .hero__overlay {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0) 40%,
      rgba(0, 0, 0, 0.2) 60%,
      rgba(0, 0, 0, 0.62) 100%
    );
  }

  /* Текст — окрема анімація появи, не прив'язана до руху картинки */
  .hero__text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 48px 24px;
    max-width: 1200px;
    margin: 0 auto;
    color: #fff;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: 0s;
  }
  /* Коли слайд активний — текст плавно з'являється із затримкою,
     щоб зʼявитись вже після того, як картинка майже доїхала (1.5с) */
  .hero__slide.is-visible .hero__text {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 1.1s;
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.05;
    font-weight: 600;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
    max-width: 22ch;
    color: #fff;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5), 0 1px 3px rgba(0, 0, 0, 0.4);
  }
  .hero__subtitle {
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.45;
    margin: 0 0 24px;
    max-width: 48ch;
    opacity: 0.95;
    color: #fff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5), 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  .hero__slide-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .hero__slide-btn svg {
    transition: transform 0.2s ease;
  }
  .hero__slide:hover .hero__slide-btn,
  .hero__slide:focus-visible .hero__slide-btn {
    background: rgba(255, 255, 255, 0.28);
  }
  .hero__slide:hover .hero__slide-btn svg,
  .hero__slide:focus-visible .hero__slide-btn svg {
    transform: translateX(4px);
  }

  /* Точки-перемикачі слайдів */
  .hero__dots {
    position: absolute;
    top: 24px;
    right: 24px;
    z-index: 6;
    display: flex;
    gap: 8px;
  }
  .hero__dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    transition: background 0.25s ease, width 0.25s ease, transform 0.15s ease;
  }
  .hero__dot:hover {
    background: rgba(255, 255, 255, 0.7);
    transform: scale(1.1);
  }
  .hero__dot.is-active {
    width: 26px;
    background: #fff;
  }
  .hero__dot:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  /* Сітка карток (без змін) */
  .hero__nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }
  .hero__nav-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .hero__card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 28px 24px 24px;
    background: #fff;
    border: 1px solid rgba(40, 42, 43, 0.08);
    border-radius: 12px;
    text-decoration: none;
    color: #282A2B;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    overflow: hidden;
  }
  .hero__card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: #c0392b;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .hero__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(40, 42, 43, 0.08);
    border-color: rgba(192, 57, 43, 0.15);
  }
  .hero__card:hover::before { transform: scaleX(1); }
  .hero__card-icon { color: #c0392b; margin-bottom: 16px; display: flex; }
  .hero__card-count {
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1;
    color: #282A2B;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }
  .hero__card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: #282A2B;
  }
  .hero__card-desc {
    font-size: 0.875rem;
    color: rgba(40, 42, 43, 0.6);
    line-height: 1.4;
    margin: 0 0 16px;
    flex: 1;
  }
  .hero__card-arrow {
    color: rgba(40, 42, 43, 0.3);
    align-self: flex-end;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .hero__card:hover .hero__card-arrow {
    color: #c0392b;
    transform: translateX(4px);
  }

  /* ============================================================
     Wallpaper CTA banner — under the nav grid
     ============================================================ */
  .hero__cta {
    position: relative;
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 40px 44px;
    background: linear-gradient(135deg, #c0392b 0%, #8a2418 100%);
    border-radius: 14px;
    text-decoration: none;
    color: #fff;
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(192, 57, 43, 0.22);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    min-height: 180px;
  }
  .hero__cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 48px rgba(192, 57, 43, 0.32);
  }

  .hero__cta-flowers {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero__cta-flower {
    position: absolute;
    filter: brightness(1.5) saturate(0.35);
    transition: transform 0.5s ease, opacity 0.5s ease;
    user-select: none;
  }
  .hero__cta-flower--1 {
    width: 180px;
    top: -40px;
    right: 240px;
    opacity: 0.28;
    transform: rotate(20deg);
  }