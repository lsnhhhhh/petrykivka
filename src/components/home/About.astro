---
import HomepageSection from './HomepageSection.astro';
import { sectionTitles, aboutText, aboutLink } from '../../data/homepage';

interface Props {
  locale: 'uk' | 'en';
}

const { locale } = Astro.props;
---

<HomepageSection title={sectionTitles.about[locale]}>
  <div class="about">
    <p class="about__text">{aboutText[locale]}</p>
    <a href={aboutLink[locale].href} class="about__link">
      <span>{aboutLink[locale].text}</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>
</HomepageSection>

<style>
  .about {
    max-width: 760px;
  }
  .about__text {
    font-size: 1.1875rem;
    line-height: 1.75;
    color: #282A2B;
    margin: 0 0 28px;
  }
  .about__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #c0392b;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    padding: 8px 0;
    border-bottom: 1px solid transparent;
    transition: gap 0.2s ease, border-color 0.2s ease;
  }
  .about__link:hover {
    gap: 12px;
    border-color: rgba(192, 57, 43, 0.25);
  }
  @media (max-width: 640px) {
    .about__text {
      font-size: 1.0625rem;
      line-height: 1.7;
    }
  }
</style>