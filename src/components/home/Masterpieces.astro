---
import HomepageSection from './HomepageSection.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { sectionTitles } from '../../data/homepage';

interface Props {
  locale: 'uk' | 'en';
}

const { locale } = Astro.props;

const artworkImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/artworks/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG}',
  { eager: true }
);

function resolveImage(img: any): ImageMetadata | null {
  if (!img) return null;
  if (typeof img !== 'string') return img as ImageMetadata;
  const absolutePath = img.replace(/^\.\.\/\.\.\/\.\.\//, '/src/');
  return artworkImages[absolutePath]?.default ?? null;
}

function getSlugOnly(id: string) {
  return id.includes('/') ? id.split('/').pop()! : id;
}

const allArtworks = await getCollection('artworks');
const featured = allArtworks
  .filter((a) => a.data.locale === locale && a.data.featured === true)
  .sort((a, b) => (a.data.featuredOrder ?? 999) - (b.data.featuredOrder ?? 999))
  .map((a) => ({
    slug: getSlugOnly(a.id),
    title: a.data.title,
    master: a.data.master,
    year: a.data.year,
    caption: a.data.featuredCaption?.[locale] ?? '',
    image: resolveImage(a.data.image),
  }));

const viewAllText = locale === 'uk' ? 'Уся галерея' : 'Full gallery';
const viewAllHref = locale === 'uk' ? '/gallery' : '/en/gallery';

function artworkUrl(slug: string) {
  return locale === 'uk' ? `/gallery/${slug}` : `/en/gallery/${slug}`;
}
---

{featured.length > 0 && (
  <HomepageSection
    title={sectionTitles.masterpieces[locale]}
    viewAllHref={viewAllHref}
    viewAllText={viewAllText}
    background="cream"
  >
    <div class="masterpieces">
      {featured.map((art) => (
        <a href={artworkUrl(art.slug)} class="mp">
          <div class="mp__caption">{art.caption}</div>
          {art.image && (
            <Image
              src={art.image}
              alt={art.title}
              widths={[360, 540, 720]}
              sizes="(max-width: 700px) 90vw, (max-width: 1100px) 45vw, 32vw"
              class="mp__image"
            />
          )}
          <div class="mp__info">
            <h3 class="mp__title">{art.title}</h3>
            <div class="mp__meta">
              {art.master}{art.year ? ` · ${art.year}` : ''}
            </div>
          </div>
        </a>
      ))}
    </div>
  </HomepageSection>
)}

<style>
  .masterpieces {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 36px;
    align-items: start;
  }
  .mp {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }
  .mp:hover {
    transform: translateY(-3px);
  }
  .mp__caption {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #c0392b;
    letter-spacing: 0.08em;
    line-height: 1.3;
    min-height: 1.7em;
  }
  .mp__image {
    width: 100% !important;
    height: auto !important;
    object-fit: unset !important;
    border-radius: 0 !important;
    display: block;
    transition: box-shadow 0.25s ease, transform 0.3s ease;
  }
  .mp:hover .mp__image {
    box-shadow: 0 16px 36px rgba(40, 42, 43, 0.16);
  }
  .mp__info {
    padding: 4px 2px 0;
  }
  .mp__title {
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: #282A2B;
    line-height: 1.3;
    transition: color 0.15s ease;
  }
  .mp:hover .mp__title {
    color: #c0392b;
  }
  .mp__meta {
    font-size: 0.875rem;
    color: rgba(40, 42, 43, 0.6);
    line-height: 1.4;
  }

  @media (max-width: 1100px) {
    .masterpieces {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 28px;
    }
  }
  @media (max-width: 520px) {
    .masterpieces {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>