---
interface Props {
  title: string;
  subtitle?: string;
  viewAllHref?: string;
  viewAllText?: string;
  background?: 'default' | 'cream';
  id?: string;
}

const {
  title,
  subtitle,
  viewAllHref,
  viewAllText,
  background = 'default',
  id,
} = Astro.props;
---

<section
  class:list={['hp-section', background === 'cream' && 'hp-section--cream']}
  id={id}
>
  <div class="hp-section__container">
    <div class="hp-section__header">
      <div class="hp-section__heading">
        <h2 class="hp-section__title">{title}</h2>
        {subtitle && <p class="hp-section__subtitle">{subtitle}</p>}
      </div>
      {viewAllHref && (
        <a href={viewAllHref} class="hp-section__link">
          <span>{viewAllText || 'Дивитись всі'}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      )}
    </div>
    <div class="hp-section__content">
      <slot />
    </div>
  </div>
</section>

<style>
  .hp-section {
    padding: 80px 0;
    background: #FFFDFB;
  }
  .hp-section--cream {
    background: #F8F4EE;
  }
  .hp-section__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .hp-section__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 36px;
  }
  .hp-section__heading {
    flex: 1;
    min-width: 0;
    padding-left: 16px;
    border-left: 3px solid #c0392b;
  }
  .hp-section__title {
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.2;
    font-weight: 600;
    color: #282A2B;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .hp-section__subtitle {
    font-size: 1rem;
    color: rgba(40, 42, 43, 0.65);
    margin: 6px 0 0;
    line-height: 1.5;
  }
  .hp-section__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #c0392b;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    white-space: nowrap;
    padding: 8px 0;
    transition: gap 0.2s ease;
  }
  .hp-section__link:hover {
    gap: 12px;
  }
  @media (max-width: 640px) {
    .hp-section {
      padding: 56px 0;
    }
    .hp-section__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 28px;
    }
    .hp-section__title {
      font-size: 1.5rem;
    }
  }
</style>