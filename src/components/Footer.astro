    <p class="footer-copy">&copy; {today.getFullYear()} {locale === 'uk' ? 'Петриківський розпис' : 'Petrykivka Painting'}</p>
  </div>
</footer>
<style is:global>
  footer {
    padding: 2.5em 1em;
    background: #FFFDFB;
    border-top: 1px solid rgb(229, 233, 240);
    color: rgb(96, 115, 159);
    text-align: center;
  }
  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.75rem;
    margin-bottom: 1.5rem;
  }
  .footer-links a {
    color: rgb(55, 65, 81);
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: #c0392b;
  }
  .footer-social {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .footer-social a {
    color: rgb(96, 115, 159);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, transform 0.2s;
  }
  .footer-social a:hover {
    color: #c0392b;
    transform: translateY(-2px);
  }
  .footer-social svg {
    display: block;
  }
  .footer-copy {
    margin: 0;
    font-size: 0.85rem;
    color: rgb(156, 163, 175);
  }
</style>