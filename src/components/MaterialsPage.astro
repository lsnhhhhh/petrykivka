---
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { t } from '../i18n/translations';
import { filterByLocale, getContentUrl } from '../i18n/content';
import type { Locale } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const allMaterials = await getCollection('materials');
const materials = filterByLocale(allMaterials, locale);

const sorted = materials.sort((a, b) => {
  if (!a.data.pubDate) return 1;
  if (!b.data.pubDate) return -1;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const categories = ['Галереї', 'Статті', 'Майстер-класи', 'Відео'];

const categoryNamesEn: Record<string, string> = {
  'Галереї': 'Galleries',
  'Статті': 'Articles',
  'Майстер-класи': 'Masterclasses',
  'Відео': 'Videos',
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={t(locale, 'nav.materials')} description={t(locale, 'nav.materials')} />
    <style>
      h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
      .subtitle { color: rgb(96, 115, 159); font-size: 1.1rem; margin-bottom: 2rem; }
      .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgb(229, 233, 240); }
      .filter-btn { padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid rgb(229, 233, 240); color: #000; background: white; cursor: pointer; transition: all 0.2s; font-family: inherit; }
      .filter-btn:hover, .filter-btn.active { border-color: #c0392b; color: #c0392b; background: #fff0ee; }
      .materials-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
      .material-card { border-radius: 12px; overflow: hidden; border: 1px solid rgb(229, 233, 240); text-decoration: none; color: inherit; display: block; transition: transform 0.2s, box-shadow 0.2s; }
      .material-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1); border-color: transparent; }
      .material-card[data-hidden] { display: none; }
      .cover-image { width: 100%; height: 200px; object-fit: cover; display: block; }
      .cover-placeholder { width: 100%; height: 200px; background: rgb(229, 233, 240); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
      .card-info { padding: 1rem 1.25rem 1.25rem; }
      .card-category { font-size: 0.8rem; color: #c0392b; font-weight: 700; margin: 0 0 0.4rem; text-transform: uppercase; letter-spacing: 0.05em; }
      .card-title { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.4rem; line-height: 1.3; }
      .card-description { font-size: 0.85rem; color: rgb(96, 115, 159); margin: 0; line-height: 1.5; }
      .empty { text-align: center; color: rgb(96, 115, 159); padding: 3rem 0; display: none; }
      .empty.visible { display: block; }
      @media (max-width: 720px) { .materials-grid { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>{t(locale, 'nav.materials')}</h1>
      <p class="subtitle">
        {locale === 'uk'
          ? 'Галереї, статті, майстер-класи та відео про петриківський розпис'
          : 'Galleries, articles, masterclasses and videos about Petrykivka painting'}
      </p>

      <div class="filters">
        <button class="filter-btn active" data-filter="all">{locale === 'uk' ? 'Всі' : 'All'}</button>
        {categories.map(cat => (
          <button class="filter-btn" data-filter={cat}>
            {locale === 'en' ? (categoryNamesEn[cat] || cat) : cat}
          </button>
        ))}
      </div>

      <div class="materials-grid" id="grid">
        {sorted.map(material => (
          <a href={getContentUrl('materials', material.id)} class="material-card" data-category={material.data.category}>
            {material.data.cover
              ? <Image src={material.data.cover} alt={material.data.title} width={300} height={200} class="cover-image" />
              : <div class="cover-placeholder">📄</div>
            }
            <div class="card-info">
              <p class="card-category">
                {locale === 'en' ? (categoryNamesEn[material.data.category] || material.data.category) : material.data.category}
              </p>
              <p class="card-title">{material.data.title}</p>
              {material.data.description && <p class="card-description">{material.data.description}</p>}
            </div>
          </a>
        ))}
      </div>

      <p class="empty" id="empty">
        {locale === 'uk' ? 'Матеріалів у цій категорії ще немає' : 'No materials in this category yet'}
      </p>
    </main>
    <Footer />

    <script is:inline>
      const buttons = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.material-card');
      const empty = document.getElementById('empty');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const filter = btn.dataset.filter;
          let visible = 0;
          cards.forEach(card => {
            if (filter === 'all' || card.dataset.category === filter) {
              card.removeAttribute('data-hidden');
              visible++;
            } else {
              card.setAttribute('data-hidden', '');
            }
          });
          empty.classList.toggle('visible', visible === 0);
        });
      });
    </script>
  </body>
</html>