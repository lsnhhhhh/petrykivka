+)}
+<script is:inline>
+  // Universal helper for firing custom GA4 events from any page/component.
+  // Safe no-op if gtag isn't loaded (local dev, ad-blockers, etc.) so it
+  // never needs to be feature-detected at every call site.
+  window.trackEvent = function (name, params) {
+    try {
+      if (typeof window.gtag === 'function') {
+        window.gtag('event', name, params || {});
+      }
+    } catch (e) { /* ignore */ }
+  };
+
+  // Site-wide outbound link tracking (book externalUrl/pdfUrl, center websites,
+  // any other target="_blank" link) without needing to instrument every page.
+  document.addEventListener('click', function (e) {
+    var a = e.target && e.target.closest && e.target.closest('a[target="_blank"]');
+    if (!a || !a.href) return;
+    var domain = a.href;
+    try { domain = new URL(a.href).hostname; } catch (_) { /* ignore */ }
+    window.trackEvent('outbound_click', {
+      link_url: a.href,
+      link_domain: domain,
+      link_class: a.className || '(none)',
+      page_path: location.pathname,
+    });
+  }, true);
+</script>
