---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const allMasters = await getCollection('masters');
  return allMasters.map(master => ({
    params: { id: master.id },
    props: { master, allMasters },
  }));
}

const { master, allMasters } = Astro.props;
const { Content } = await render(master);

function getMasterUrl(name) {
  const found = allMasters.find(m => m.data.name === name);
  return found ? '/masters/' + found.id : null;
}

const resolvedTagGroups = [
  { label: 'Осередок', values: master.data.center ? [master.data.center] : [], type: 'tag' },
  { label: 'Період', values: master.data.period ? [master.data.period] : [], type: 'tag' },
  { label: 'Школа', values: master.data.school || [], type: 'tag' },
  { label: 'Вчителі', values: master.data.teachers || [], type: 'master' },
  { label: 'Вплив на', values: master.data.influenced || [], type: 'master' },
].map(group => ({
  ...group,
  items: group.values.map(value => ({
    value,
    url: group.type === 'master' ? (getMasterUrl(value) || '/masters/tags/' + value) : '/masters/tags/' + value,
    isMaster: group.type === 'master' && getMasterUrl(value) !== null,
  })),
}));

const allBooks = await getCollection('books');
const masterBooks = allBooks.filter(book =>
  book.data.masters && book.data.masters.includes(master.data.name)
);
---
<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title={master.data.name} description={master.data.name} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/css/glightbox.min.css" />
    <style>
      .tag-link {
        display: inline-block;
        background: #f0f0f0;
        padding: 2px 10px;
        border-radius: 12px;
        margin: 2px;
        text-decoration: none;
        color: inherit;
      }
      .master-link {
        display: inline-block;
        background: #fff0ee;
        padding: 2px 10px;
        border-radius: 12px;
        margin: 2px;
        text-decoration: none;
        color: #c0392b;
        border: 1px solid #f5c6c0;
      }
      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
      figcaption {
        font-size: 0.8rem;
        color: rgb(96,115,159);
        padding: 0.4rem 0;
        text-align: center;
      }
      .meta-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(229,233,240);
      }
      .meta-row {
        margin-bottom: 0.75rem;
      }
      .books-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(229,233,240);
      }
      .books-section h2 {
        font-size: 1.2rem;
        margin-bottom: 1rem;
      }
      .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }
      .book-card {
        text-decoration: none;
        color: inherit;
        display: block;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgb(229,233,240);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .book-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        border-color: transparent;
      }
      .book-cover-placeholder {
        width: 100%;
        height: 200px;
        background: rgb(229,233,240);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
      }
      .book-info {
        padding: 0.75rem;
      }
      .book-title {
        font-size: 0.9rem;
        font-weight: 700;
        margin: 0 0 0.25rem;
        line-height: 1.3;
      }
      .book-author {
        font-size: 0.8rem;
        color: rgb(96,115,159);
        margin: 0;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href="/masters">← Всі майстри</a>
      <h1>{master.data.name}</h1>

      {master.data.photo && (
        <div style="margin: 1.5rem 0;">
          <Image
            src={master.data.photo}
            alt={master.data.name}
            width={800}
            height={500}
            style="border-radius: 8px; width: 100%; max-width: 800px; height: auto; display: block;"
          />
        </div>
      )}

      <Content />

      {master.data.galleryGroups && master.data.galleryGroups.length > 0 && (
        <div>
          {master.data.galleryGroups.map(group => (
            <section style="margin-top: 2rem;">
              <h2>{group.title}</h2>
              <div class="gallery-grid">
                {group.items.map((item, i) => (
                  <a href={item.image.src} class="glightbox" data-gallery={group.title} data-description={item.caption || ''}>
                    <figure style="margin: 0;">
                      <Image
                        src={item.image}
                        alt={item.caption || 'Робота ' + (i + 1)}
                        width={300}
                        height={300}
                        style="border-radius: 8px; object-fit: cover; width: 100%; height: 200px; cursor: pointer; display: block;"
                      />
                      {item.caption && (
                        <figcaption>{item.caption}</figcaption>
                      )}
                    </figure>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}

      <section class="meta-section">
        {resolvedTagGroups.map(group => group.items.length > 0 && (
          <div class="meta-row">
            <strong>{group.label}:</strong>{' '}
            {group.items.map(item => (
              <a href={item.url} class={item.isMaster ? 'master-link' : 'tag-link'}>
                {item.value}
              </a>
            ))}
          </div>
        ))}
        <div class="meta-row">
          <strong>Категорія:</strong> {master.data.category}
        </div>
      </section>

      {masterBooks.length > 0 && (
        <section class="books-section">
          <h2>Книги про цього майстра</h2>
          <div class="books-grid">
            {masterBooks.map(book => (
              <a href={'/books/' + book.id} class="book-card">
                {book.data.cover
                  ? (
                    <Image
                      src={book.data.cover}
                      alt={book.data.title}
                      width={160}
                      height={200}
                      style="width: 100%; height: 200px; object-fit: cover; display: block;"
                    />
                  ) : (
                    <div class="book-cover-placeholder">📖</div>
                  )
                }
                <div class="book-info">
                  <p class="book-title">{book.data.title}</p>
                  {book.data.author && (
                    <p class="book-author">{book.data.author}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
    <Footer />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/js/glightbox.min.js"></script>
    <script>
      const lightbox = GLightbox({ selector: '.glightbox' });
    </script>
  </body>
</html>