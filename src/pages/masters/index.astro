---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allMasters = await getCollection('masters');

const categories = [
  'Старі майстри',
  'Друге покоління',
  'Третє покоління',
  'Сучасні майстри',
  'Мистецтвознавці',
];

const mastersByCategory = categories.map(category => ({
  category,
  masters: allMasters.filter(m => m.data.category === category),
})).filter(group => group.masters.length > 0);
---

<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title="Майстри" description="Майстри петриківського розпису" />
    <style>
      h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      .subtitle {
        color: rgb(96, 115, 159);
        font-size: 1.1rem;
        margin-bottom: 2rem;
      }
      .nav-anchors {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 3rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgb(229, 233, 240);
      }
      .nav-anchors a {
        text-decoration: none;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        border: 1px solid rgb(229, 233, 240);
        color: rgb(0, 0, 0);
        transition: all 0.2s;
      }
      .nav-anchors a:hover {
        border-color: #c0392b;
        color: #c0392b;
      }
      .category-section {
        margin-bottom: 4rem;
      }
      .category-section h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #c0392b;
        display: inline-block;
      }
      .masters-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1.5rem;
      }
      .master-card {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgb(229, 233, 240);
        text-decoration: none;
        color: inherit;
        display: block;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .master-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        border-color: transparent;
      }
      .master-photo {
        width: 100%;
        height: 240px;
        object-fit: cover;
        display: block;
      }
      .master-photo-placeholder {
        width: 100%;
        height: 240px;
        background: rgb(229, 233, 240);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
      }
      .master-info {
        padding: 1rem 1.25rem 1.25rem;
      }
      .master-name {
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0 0 0.3rem;
        line-height: 1.3;
      }
      .master-dates {
        font-size: 0.8rem;
        color: rgb(96, 115, 159);
        margin: 0;
      }
      @media (max-width: 720px) {
        .masters-grid {
          grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
          gap: 1rem;
        }
        .master-photo,
        .master-photo-placeholder {
          height: 180px;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Майстри</h1>
      <p class="subtitle">Майстри петриківського декоративно-орнаментального розпису</p>

      <nav class="nav-anchors">
        {mastersByCategory.map(group => (
          <a href={'#' + group.category.toLowerCase().replace(/ /g, '-')}>
            {group.category}
          </a>
        ))}
      </nav>

      {mastersByCategory.map(group => (
        <section
          class="category-section"
          id={group.category.toLowerCase().replace(/ /g, '-')}
        >
          <h2>{group.category}</h2>
          <div class="masters-grid">
            {group.masters.map(master => (
              <a href={'/masters/' + master.id} class="master-card">
                {master.data.photo
                  ? (
                    <Image
                      src={master.data.photo}
                      alt={master.data.name}
                      width={220}
                      height={240}
                      class="master-photo"
                    />
                  ) : (
                    <div class="master-photo-placeholder">👤</div>
                  )
                }
                <div class="master-info">
                  <p class="master-name">{master.data.name}</p>
                  {master.data.born && (
                    <p class="master-dates">
                      {master.data.born}{master.data.died && ' — ' + master.data.died}
                    </p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>
    <Footer />
  </body>
</html>