---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allMasters = await getCollection('masters');

const categories = [
  'Старі майстри',
  'Друге покоління',
  'Третє покоління',
  'Сучасні майстри',
  'Мистецтвознавці',
];

const mastersByCategory = categories.map(category => ({
  category,
  masters: allMasters.filter(m => m.data.category === category),
})).filter(group => group.masters.length > 0);
---

<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title="Майстри" description="Майстри петриківського розпису" />
  </head>
  <body>
    <Header />
    <main>
      <h1>Майстри</h1>
      {mastersByCategory.map(group => (
        <section style="margin-bottom: 3rem;">
          <h2>{group.category}</h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem;">
            {group.masters.map(master => (
              <a href={'/masters/' + master.id} style="text-decoration: none; color: inherit;">
                <div style="border-radius: 8px; overflow: hidden; border: 1px solid #eee;">
                  {master.data.photo
                    ? (
                      <Image
                        src={master.data.photo}
                        alt={master.data.name}
                        width={200}
                        height={200}
                        style="width: 100%; height: 200px; object-fit: cover; display: block;"
                      />
                    ) : (
                      <div style="width: 100%; height: 200px; background: #f5f5f5; display: flex; align-items: center; justify-content: center; font-size: 3rem;">
                        👤
                      </div>
                    )
                  }
                  <div style="padding: 0.75rem;">
                    <strong style="font-size: 1.1rem; display: block; margin-bottom: 0.25rem;">{master.data.name}</strong>
                    {master.data.born && (
                      <p style="font-size: 0.75rem; color: #888; margin: 0;">
                        {master.data.born}{master.data.died && ' — ' + master.data.died}
                      </p>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>
    <Footer />
  </body>
</html>