---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import { getLocaleFromUrl } from '../../i18n/translations';
import { filterByLocale, getContentUrl } from '../../i18n/content';

export async function getStaticPaths() {
  const allCenters = await getCollection('centers');
  const ukCenters = allCenters.filter(c => c.id.startsWith('uk/'));
  return ukCenters.map(center => ({
    params: { id: center.id.replace('uk/', '') },
    props: { center },
  }));
}

const { center } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const { Content } = await render(center);

const allMasters = await getCollection('masters');
const localeMasters = filterByLocale(allMasters, locale);
const centerMasters = center.data.masters
  ? localeMasters.filter(m => center.data.masters.includes(m.data.name))
  : [];

const allArtworks = await getCollection('artworks');
const centerArtworks = filterByLocale(allArtworks, locale).filter(
  a => a.data.location === center.data.name
);

const { founded, closed } = center.data;
const foundedLabel = founded
  ? closed
    ? `${founded}–${closed}`
    : locale === 'uk' ? `${founded} – по сьогодні` : `${founded} – present`
  : null;
---
<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={center.data.name} description={center.data.name} />
    <style>
      .meta-section { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgb(229,233,240); }
      .meta-row { margin-bottom: 0.75rem; font-size: 0.95rem; }
      .meta-row strong { color: rgb(0,0,0); }
      .masters-section { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgb(229,233,240); }
      .masters-section h2 { font-size: 1.2rem; margin-bottom: 1rem; }
      .masters-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; }
      .master-card { text-decoration: none; color: inherit; display: block; border-radius: 8px; overflow: hidden; border: 1px solid rgb(229,233,240); transition: transform 0.2s, box-shadow 0.2s; }
      .master-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); border-color: transparent; }
      .master-photo-placeholder { width: 100%; height: 180px; background: rgb(229,233,240); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
      .master-info { padding: 0.75rem; }
      .master-name { font-size: 0.9rem; font-weight: 700; margin: 0; line-height: 1.3; }
      .website-link { display: inline-block; margin-top: 1rem; padding: 0.6rem 1.75rem; border-radius: 30px; text-decoration: none; font-size: 1rem; border: 2px solid #c0392b; color: #c0392b; font-weight: 500; transition: all 0.2s; }
      .website-link:hover { background: #c0392b; color: white; }
      .back-link { display: inline-block; margin-bottom: 1.5rem; color: rgb(96, 115, 159); text-decoration: none; font-size: 0.95rem; }
      .back-link:hover { color: #c0392b; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href={locale === 'en' ? '/en/centers' : '/centers'} class="back-link" id="back-link">
        {locale === 'uk' ? '← Всі осередки' : '← All centers'}
      </a>
      <h1>{center.data.name}</h1>

      {center.data.photo && (
        <div style="margin: 1.5rem 0;">
          <Image src={center.data.photo} alt={center.data.name} width={800} height={450}
            style="border-radius: 8px; width: 100%; max-width: 800px; height: auto; display: block;" />
        </div>
      )}

      <section class="meta-section">
        <div class="meta-row">
          <strong>{locale === 'uk' ? 'Категорія' : 'Category'}:</strong> {center.data.category}
        </div>
        {center.data.location && (
          <div class="meta-row">
            <strong>{locale === 'uk' ? 'Розташування' : 'Location'}:</strong> {center.data.location}
          </div>
        )}
        {foundedLabel && (
          <div class="meta-row">
            <strong>{locale === 'uk' ? 'Роки діяльності' : 'Years active'}:</strong> {foundedLabel}
          </div>
        )}
        {center.data.address && (
          <div class="meta-row">
            <strong>{locale === 'uk' ? 'Адреса' : 'Address'}:</strong> {center.data.address}
          </div>
        )}
        {center.data.website && (
          <a href={center.data.website} target="_blank" class="website-link">
            {locale === 'uk' ? 'Відвідати сайт' : 'Visit website'}
          </a>
        )}
      </section>

      <Content />

      {centerMasters.length > 0 && (
        <section class="masters-section">
          <h2>{locale === 'uk' ? "Пов'язані майстри та дослідники" : 'Related masters and researchers'}</h2>
          <div class="masters-grid">
            {centerMasters.map(master => (
              <a href={getContentUrl('masters', master.id)} class="master-card">
                {master.data.photo
                  ? <Image src={master.data.photo} alt={master.data.name} width={160} height={180}
                      style="width: 100%; height: 180px; object-fit: cover; display: block;" />
                  : <div class="master-photo-placeholder">👤</div>
                }
                <div class="master-info">
                  <p class="master-name">{master.data.name}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
      {centerArtworks.length > 0 && (
        <section class="masters-section">
          <h2>{locale === 'uk' ? 'Роботи з колекції' : 'Works from collection'}</h2>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
            {centerArtworks.map(artwork => (
              <a href={getContentUrl('gallery', artwork.id)} style="text-decoration: none; color: inherit; display: block;">
                <figure style="margin: 0;">
                  <Image
                    src={artwork.data.image}
                    alt={artwork.data.title}
                    width={300}
                    height={300}
                    style="width: 100%; height: auto; object-fit: contain; display: block; border-radius: 0;"
                  />
                  <figcaption style="font-size: 0.8rem; color: rgb(96,115,159); padding: 0.4rem 0;">
                    {artwork.data.title}{artwork.data.year ? `, ${artwork.data.year}` : ''}
                  </figcaption>
                </figure>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
    <Footer />
    <script is:inline>
      // Restore scroll position via back link
      var backLink = document.getElementById('back-link');
      if (backLink) {
        var ref = document.referrer;
        if (ref && ref.includes('/centers')) {
          backLink.addEventListener('click', function(e) {
            e.preventDefault();
            history.back();
          });
        }
      }
    </script>
  </body>
</html>