---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const allCenters = await getCollection('centers');
  return allCenters.map(center => ({
    params: { id: center.id },
    props: { center },
  }));
}

const { center } = Astro.props;
const { Content } = await render(center);

const allMasters = await getCollection('masters');
const centerMasters = center.data.masters
  ? allMasters.filter(m => center.data.masters.includes(m.data.name))
  : [];
---
<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title={center.data.name} description={center.data.name} />
    <style>
      .meta-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(229,233,240);
      }
      .meta-row {
        margin-bottom: 0.75rem;
        font-size: 0.95rem;
      }
      .meta-row strong {
        color: rgb(0,0,0);
      }
      .masters-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(229,233,240);
      }
      .masters-section h2 {
        font-size: 1.2rem;
        margin-bottom: 1rem;
      }
      .masters-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }
      .master-card {
        text-decoration: none;
        color: inherit;
        display: block;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgb(229,233,240);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .master-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        border-color: transparent;
      }
      .master-photo-placeholder {
        width: 100%;
        height: 180px;
        background: rgb(229,233,240);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
      }
      .master-info {
        padding: 0.75rem;
      }
      .master-name {
        font-size: 0.9rem;
        font-weight: 700;
        margin: 0;
        line-height: 1.3;
      }
      .website-link {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.6rem 1.75rem;
        border-radius: 30px;
        text-decoration: none;
        font-size: 1rem;
        border: 2px solid #c0392b;
        color: #c0392b;
        font-weight: 500;
        transition: all 0.2s;
      }
      .website-link:hover {
        background: #c0392b;
        color: white;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href="/centers">← Всі осередки</a>
      <h1>{center.data.name}</h1>

      {center.data.photo && (
        <div style="margin: 1.5rem 0;">
          <Image
            src={center.data.photo}
            alt={center.data.name}
            width={800}
            height={450}
            style="border-radius: 8px; width: 100%; max-width: 800px; height: auto; display: block;"
          />
        </div>
      )}

      <section class="meta-section">
        <div class="meta-row">
          <strong>Категорія:</strong> {center.data.category}
        </div>
        {center.data.location && (
          <div class="meta-row">
            <strong>Розташування:</strong> {center.data.location}
          </div>
        )}
        {center.data.founded && (
          <div class="meta-row">
            <strong>Засновано:</strong> {center.data.founded}
          </div>
        )}
        {center.data.address && (
          <div class="meta-row">
            <strong>Адреса:</strong> {center.data.address}
          </div>
        )}
        {center.data.website && (
          <a href={center.data.website} target="_blank" class="website-link">
            Відвідати сайт
          </a>
        )}
      </section>

      <Content />

      {centerMasters.length > 0 && (
        <section class="masters-section">
          <h2>Пов'язані майстри</h2>
          <div class="masters-grid">
            {centerMasters.map(master => (
              <a href={'/masters/' + master.id} class="master-card">
                {master.data.photo
                  ? (
                    <Image
                      src={master.data.photo}
                      alt={master.data.name}
                      width={160}
                      height={180}
                      style="width: 100%; height: 180px; object-fit: cover; display: block;"
                    />
                  ) : (
                    <div class="master-photo-placeholder">👤</div>
                  )
                }
                <div class="master-info">
                  <p class="master-name">{master.data.name}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
    <Footer />
  </body>
</html>