---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title="Пошук" description="Пошук по сайту" />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <h1>Пошук</h1>
      <div id="search"></div>
    </main>
    <Footer />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: 'Пошук по сайту...',
          zero_results: 'Нічого не знайдено для [SEARCH_TERM]',
        }
      });
    </script>
  </body>
</html>