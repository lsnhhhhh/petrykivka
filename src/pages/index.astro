---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FactsSlideshow from '../components/FactsSlideshow.astro';
import FeaturedCarousel from '../components/FeaturedCarousel.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, t } from '../i18n/translations';
import { filterByLocale, getContentUrl } from '../i18n/content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const locale = getLocaleFromUrl(Astro.url);

const masters   = filterByLocale(await getCollection('masters'), locale);
const books     = filterByLocale(await getCollection('books'), locale);
const centers   = filterByLocale(await getCollection('centers'), locale);
const materials = filterByLocale(await getCollection('materials'), locale);
const blog      = filterByLocale(await getCollection('blog'), locale);
const artworks  = filterByLocale(await getCollection('artworks'), locale);

const sections = locale === 'uk' ? [
  { title: 'Майстри', desc: 'Біографії та роботи майстрів петриківського розпису', url: '/masters', count: masters.length, unit: 'майстрів' },
  { title: 'Галерея', desc: 'Колекція робіт майстрів петриківського розпису', url: '/gallery', count: artworks.length, unit: 'робіт' },
  { title: 'Осередки', desc: 'Школи, музеї, організації та установи', url: '/centers', count: centers.length, unit: 'осередків' },
  { title: 'Книги', desc: 'Бібліографія видань про петриківський розпис', url: '/books', count: books.length, unit: 'книг' },
  { title: 'Матеріали', desc: 'Статті, галереї, майстер-класи та відео', url: '/materials', count: materials.length, unit: 'матеріалів' },
] : [
  { title: 'Masters', desc: 'Biographies and works of Petrykivka painting masters', url: '/en/masters', count: masters.length, unit: 'masters' },
  { title: 'Gallery', desc: 'Collection of works by Petrykivka painting masters', url: '/en/gallery', count: artworks.length, unit: 'works' },
  { title: 'Centers', desc: 'Schools, museums, organizations and institutions', url: '/en/centers', count: centers.length, unit: 'centers' },
  { title: 'Books', desc: 'Bibliography of publications about Petrykivka painting', url: '/en/books', count: books.length, unit: 'books' },
  { title: 'Materials', desc: 'Articles, galleries, masterclasses and videos', url: '/en/materials', count: materials.length, unit: 'materials' },
];
---
<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={SITE_TITLE[locale]} description={SITE_DESCRIPTION[locale]} />
    <style>
      .hero-title { font-size: 3rem; font-weight: 700; margin: 0 0 1.5rem; line-height: 1.1; text-align: center; }
      .intro { color: rgb(96, 115, 159); margin-bottom: 2rem; }
      .sections-heading { font-size: 1.2rem; font-weight: 700; margin: 0 0 1rem; color: rgb(15, 18, 25); }
      .sections-list { display: flex; flex-direction: column; gap: 0; border: 1px solid rgb(229, 233, 240); border-radius: 12px; overflow: hidden; margin-bottom: 0; }
      .section-item { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; text-decoration: none; color: inherit; border-bottom: 1px solid rgb(229, 233, 240); transition: background 0.15s; gap: 1rem; }
      .section-item:last-child { border-bottom: none; }
      .section-item:hover { background: #fafafa; }
      .section-item__left { flex: 1; min-width: 0; }
      .section-item__title { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.2rem; color: rgb(15, 18, 25); }
      .section-item__desc { font-size: 0.85rem; color: rgb(96, 115, 159); margin: 0; }
      .section-item__right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
      .section-item__count { text-align: right; }
      .section-item__num { display: block; font-size: 1.2rem; font-weight: 700; color: #c0392b; line-height: 1; }
      .section-item__unit { display: block; font-size: 0.72rem; color: rgb(96, 115, 159); margin-top: 0.1rem; }
      .section-item__arrow { color: rgb(96, 115, 159); font-size: 1rem; transition: transform 0.2s; }
      .section-item:hover .section-item__arrow { transform: translateX(3px); color: #c0392b; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1 class="hero-title">{SITE_TITLE[locale]}</h1>

      <FactsSlideshow />

      {locale === 'uk' ? (
        <>
          <p class="intro">
            Петриківський розпис — унікальне українське декоративно-орнаментальне мистецтво,
            яке виникло в селі Петриківка на Дніпропетровщині. У 2013 році ЮНЕСКО внесло
            його до списку нематеріальної культурної спадщини людства.
          </p>
          <p class="intro">
            Цей сайт — енциклопедія петриківського розпису: майстри, техніки,
            історія, матеріали та книги про це унікальне мистецтво.
          </p>
        </>
      ) : (
        <>
          <p class="intro">
            Petrykivka painting is a unique Ukrainian decorative ornamental art that originated
            in the village of Petrykivka, Dnipropetrovsk region. In 2013, UNESCO inscribed it
            on the Representative List of the Intangible Cultural Heritage of Humanity.
          </p>
          <p class="intro">
            This website is an encyclopedia of Petrykivka painting: masters, techniques,
            history, materials and books about this unique art form.
          </p>
        </>
      )}

      <p class="sections-heading">{locale === 'uk' ? 'Розділи сайту:' : 'Site sections:'}</p>
      <nav class="sections-list">
        {sections.map(s => (
          <a href={s.url} class="section-item">
            <div class="section-item__left">
              <p class="section-item__title">{s.title}</p>
              <p class="section-item__desc">{s.desc}</p>
            </div>
            <div class="section-item__right">
              {s.count > 0 && (
                <div class="section-item__count">
                  <span class="section-item__num">{s.count}</span>
                  <span class="section-item__unit">{s.unit}</span>
                </div>
              )}
              <span class="section-item__arrow">→</span>
            </div>
          </a>
        ))}
      </nav>

      <FeaturedCarousel />
    </main>
    <Footer />
  </body>
</html>