---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Петриківський розпис</h1>
      <p>
        Петриківський розпис — унікальне українське декоративно-орнаментальне мистецтво,
        яке виникло в селі Петриківка на Дніпропетровщині. У 2013 році ЮНЕСКО внесло
        його до списку нематеріальної культурної спадщини людства.
      </p>
      <p>
        Цей сайт — енциклопедія петриківського розпису: майстри, техніки, історія,
        матеріали та книги про це унікальне мистецтво.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-top: 2rem;">
        <a href="/masters" style="text-decoration: none;">
          <div style="padding: 1.5rem; border: 1px solid rgb(var(--gray-light)); border-radius: 8px;">
            <h3 style="margin: 0 0 0.5rem;">Майстри</h3>
            <p style="margin: 0; font-size: 0.9em; color: rgb(var(--gray));">Біографії та роботи майстрів петриківського розпису</p>
          </div>
        </a>
        <a href="/blog" style="text-decoration: none;">
          <div style="padding: 1.5rem; border: 1px solid rgb(var(--gray-light)); border-radius: 8px;">
            <h3 style="margin: 0 0 0.5rem;">Блог</h3>
            <p style="margin: 0; font-size: 0.9em; color: rgb(var(--gray));">Статті про історію та техніки петриківського розпису</p>
          </div>
        </a>
        <a href="/books" style="text-decoration: none;">
          <div style="padding: 1.5rem; border: 1px solid rgb(var(--gray-light)); border-radius: 8px;">
            <h3 style="margin: 0 0 0.5rem;">Книги</h3>
            <p style="margin: 0; font-size: 0.9em; color: rgb(var(--gray));">Бібліографія видань про петриківський розпис</p>
          </div>
        </a>
        <a href="/materials" style="text-decoration: none;">
          <div style="padding: 1.5rem; border: 1px solid rgb(var(--gray-light)); border-radius: 8px;">
            <h3 style="margin: 0 0 0.5rem;">Матеріали</h3>
            <p style="margin: 0; font-size: 0.9em; color: rgb(var(--gray));">Архівні матеріали, документи, відео</p>
          </div>
        </a>
      </div>
    </main>
    <Footer />
  </body>
</html>