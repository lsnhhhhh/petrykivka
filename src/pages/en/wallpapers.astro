---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WallpaperMaker from '../../components/WallpaperMaker.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <BaseHead
      title="Create your own Petrykivka wallpaper"
      description="Make a unique Petrykivka-style wallpaper for your phone, tablet, or desktop."
    />
  </head>
  <body>
    <Header />
    <main class="wm-main">
      <WallpaperMaker locale="en" />
    </main>
    <Footer />
    <style>
      .wm-main { width: 100%; max-width: none; margin: 0; padding: 0; }
    </style>
  </body>
</html>
