---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getLocaleFromUrl, t } from '../../../i18n/translations';
import { filterByLocale, getContentUrl } from '../../../i18n/content';

export async function getStaticPaths() {
  const allArtworks = await getCollection('artworks');
  const enArtworks = allArtworks.filter(a => a.id.startsWith('en/'));
  return enArtworks.map(artwork => ({
    params: { id: artwork.id.replace('en/', '') },
    props: { artwork },
  }));
}

const { artwork } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);

const allMasters = await getCollection('masters');
const localeMasters = filterByLocale(allMasters, locale);
const masterEntry = localeMasters.find(m => m.data.name === artwork.data.master);
const masterUrl = masterEntry ? getContentUrl('masters', masterEntry.id) : null;
const allCenters = await getCollection('centers');
const localeCenters = filterByLocale(allCenters, locale);
const locationCenter = artwork.data.location
  ? localeCenters.find(c => c.data.name === artwork.data.location)
  : null;
const locationUrl = locationCenter ? getContentUrl('centers', locationCenter.id) : null;

const labels = { materials: 'Materials', dimensions: 'Dimensions', location: 'Collection', elements: 'Key elements', back: '← All works' };
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${artwork.data.title} — ${artwork.data.master}`} description={artwork.data.description || artwork.data.title} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/css/glightbox.min.css" />
    <style>
      .back-link { display: inline-block; margin-bottom: 1.5rem; color: rgb(96, 115, 159); text-decoration: none; font-size: 0.95rem; }
      .back-link:hover { color: #c0392b; }
      .artwork-hero { max-width: 720px; margin: 0 auto 2.5rem; }
      .artwork-hero img { width: 100%; height: auto; display: block; border-radius: 0; }
      .artwork-details { max-width: 720px; margin: 0 auto; }
      .artwork-header { margin-bottom: 2rem; }
      .artwork-master-name { font-size: 1.5rem; font-weight: 700; margin: 0 0 0.15rem; line-height: 1.3; }
      .artwork-master-name a { color: inherit; text-decoration: none; border-bottom: 2px solid transparent; transition: border-color 0.2s; }
      .artwork-master-name a:hover { border-bottom-color: #c0392b; }
      .artwork-detail-title { font-size: 1.2rem; font-style: italic; color: rgb(96, 115, 159); margin: 0 0 0.25rem; font-weight: 400; }
      .artwork-detail-year { font-size: 1rem; color: rgb(96, 115, 159); margin: 0; }
      .artwork-description { font-size: 1.05rem; line-height: 1.7; color: rgb(55, 65, 81); margin-bottom: 2.5rem; }
      .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem 2rem; padding-top: 2rem; border-top: 1px solid rgb(229, 233, 240); }
      .meta-label { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgb(156, 163, 175); margin: 0 0 0.3rem; }
      .meta-value { font-size: 0.95rem; color: rgb(55, 65, 81); margin: 0; line-height: 1.4; }
      .element-tag { display: inline-block; background: rgb(243, 244, 246); padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.82rem; margin: 0.15rem 0.15rem 0 0; color: rgb(55, 65, 81); }
      @media (max-width: 600px) { .meta-grid { grid-template-columns: 1fr; } }
    </style>
  </head>
  <style is:global>
  .gslide-image img,
  .glightbox-container .gslide-image img {
    border-radius: 0 !important;
  }
  </style>
  <body>
    <Header />
    <main>
      <div style="max-width: 720px; margin: 0 auto;">
        <a href={locale === 'en' ? '/en/gallery' : '/gallery'} class="back-link" id="back-link">{labels.back}</a>
      </div>
      <div class="artwork-hero">
        <a class="glightbox" data-type="image">
          <Image
            id="artwork-main-img"
            src={artwork.data.image}
            alt={artwork.data.title}
            widths={[720, 1440]}
            sizes="(max-width: 720px) 100vw, 720px"
            style="cursor: zoom-in; width: 100%; height: auto;"
          />
        </a>
      </div>
      <div class="artwork-details">
        <div class="artwork-header">
          <p class="artwork-master-name">
            {masterUrl ? <a href={masterUrl}>{artwork.data.master}</a> : artwork.data.master}
          </p>
          <p class="artwork-detail-title">{artwork.data.title}</p>
          {artwork.data.year && <p class="artwork-detail-year">{artwork.data.year}</p>}
        </div>
        {artwork.data.description && <p class="artwork-description">{artwork.data.description}</p>}
        {(artwork.data.medium || artwork.data.dimensions || artwork.data.location || (artwork.data.elements && artwork.data.elements.length > 0)) && (
          <div class="meta-grid">
            {artwork.data.medium && <div><p class="meta-label">{labels.materials}</p><p class="meta-value">{artwork.data.medium}</p></div>}
            {artwork.data.dimensions && <div><p class="meta-label">{labels.dimensions}</p><p class="meta-value">{artwork.data.dimensions}</p></div>}
            {artwork.data.location && (
              <div class="meta-item">
                <p class="meta-label">{labels.location}</p>
                <p class="meta-value">
                  {locationUrl
                    ? <a href={locationUrl} style="color: #c0392b; text-decoration: none; border-bottom: 1px solid #f5c6c0;">{artwork.data.location}</a>
                    : artwork.data.location
                  }
                </p>
              </div>
            )}
            {artwork.data.elements && artwork.data.elements.length > 0 && (
              <div><p class="meta-label">{labels.elements}</p><div>{artwork.data.elements.map(el => <span class="element-tag">{el}</span>)}</div></div>
            )}
          </div>
        )}
      </div>
    </main>
    <div style="max-width: 720px; margin: 3rem auto 0; padding: 2rem 0 0; border-top: 1px solid rgb(229, 233, 240);">
        <p style="font-size: 0.8rem; color: rgb(156, 163, 175); line-height: 1.6; margin: 0;">
          Copyright for this work belongs to the rights holder. The image is presented solely for educational purposes and promotion of Petrykivka painting and may not be used for commercial purposes without permission from the rights holder. The storage location or owner of the work is indicated in the artwork description. For clarifications or additional information, please reach out via our <a href="/en/contacts" style="color: rgb(156, 163, 175); border-bottom: 1px solid rgb(200, 205, 215);">contacts</a>.
      </div>
    <Footer />
   <script is:inline>
      // Wait for DOM and load GLightbox
      window.addEventListener('load', function() {
        var script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/js/glightbox.min.js';
        script.onload = function() {
          // Set glightbox href to largest image from srcset
          var mainImg = document.getElementById('artwork-main-img');
          var glightboxLink = mainImg ? mainImg.closest('.glightbox') : null;
          if (mainImg && glightboxLink) {
            var srcset = mainImg.getAttribute('srcset');
            var imgUrl = mainImg.getAttribute('src');
            if (srcset) {
              var sources = srcset.split(',').map(function(s) {
                var parts = s.trim().split(' ');
                return { url: parts[0], width: parseInt(parts[1]) || 0 };
              });
              sources.sort(function(a, b) { return b.width - a.width; });
              if (sources.length > 0) imgUrl = sources[0].url;
            }
            glightboxLink.setAttribute('href', imgUrl);
          }

          GLightbox({
            selector: '.glightbox',
            closeButton: true,
            touchNavigation: true,
            keyboardNavigation: true,
            closeOnOutsideClick: true,
          });
        };
        document.head.appendChild(script);
      });

      // Restore gallery filters in back link
      var backLink = document.getElementById('back-link');
      if (backLink) {
        try {
          var params = new URLSearchParams(window.location.search);
          var from = params.get('from');
          if (from) {
            var baseHref = backLink.getAttribute('href').split('?')[0];
            backLink.setAttribute('href', baseHref + '?' + decodeURIComponent(from));
          }
        } catch(e) {}
      }
    </script>
  </body>
</html>