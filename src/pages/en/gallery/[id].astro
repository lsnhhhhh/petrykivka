---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import { getLocaleFromUrl, t } from '../../../i18n/translations';
import { filterByLocale, getContentUrl } from '../../../i18n/content';

export async function getStaticPaths() {
  const allArtworks = await getCollection('artworks');
  const enArtworks = allArtworks.filter(a => a.id.startsWith('en/'));
  return enArtworks.map(artwork => ({
    params: { id: artwork.id.replace('en/', '') },
    props: { artwork },
  }));
}

const { artwork } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);

// Повнорозмірне зображення для PhotoSwipe
const sourceWidth = (artwork.data.image as any).width || 3200;
const sourceHeight = (artwork.data.image as any).height || 2400;
const fullSize = await getImage({
  src: artwork.data.image,
  format: 'webp',
  quality: 95,
  width: Math.min(3200, sourceWidth),
});

// Майстер
const allMasters = await getCollection('masters');
const localeMasters = filterByLocale(allMasters, locale);
const masterEntry = localeMasters.find(m => m.data.name === artwork.data.master);
const masterUrl = masterEntry ? getContentUrl('masters', masterEntry.id) : null;

// URL галереї з фільтром по цьому майстрові
const galleryFilterUrl = `${locale === 'uk' ? '/gallery' : '/en/gallery'}?master=${encodeURIComponent(artwork.data.master)}`;

// Локація (центр)
const allCenters = await getCollection('centers');
const localeCenters = filterByLocale(allCenters, locale);
const locationCenter = artwork.data.location
  ? localeCenters.find(c => c.data.name === artwork.data.location)
  : null;
const locationUrl = locationCenter ? getContentUrl('centers', locationCenter.id) : null;

// Інші роботи цього майстра
const allArtworks2 = await getCollection('artworks');
const localeArtworks = filterByLocale(allArtworks2, locale);
const otherWorksByMaster = localeArtworks
  .filter(a => a.data.master === artwork.data.master && a.id !== artwork.id)
  .slice(0, 12);

const labels = locale === 'uk'
  ? { materials: 'Матеріали', dimensions: 'Розмір', location: 'Де зберігається', elements: 'Основні елементи', back: '← Всі роботи' }
  : { materials: 'Materials', dimensions: 'Dimensions', location: 'Collection', elements: 'Key elements', back: '← All works' };
---
<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={`${artwork.data.title} — ${artwork.data.master}`} description={artwork.data.description || artwork.data.title} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.css" />
    <style>
      .back-link { display: inline-block; margin-bottom: 1.5rem; color: rgb(96, 115, 159); text-decoration: none; font-size: 0.95rem; }
      .back-link:hover { color: #c0392b; }
      .artwork-hero {
        max-width: 720px; margin: 0 auto 2.5rem;
      }
      .artwork-hero img {
        width: 100%; height: auto; display: block;
        border-radius: 0;
      }
      .artwork-details {
        max-width: 720px; margin: 0 auto;
      }
      .artwork-header { margin-bottom: 2rem; }
      .artwork-master-name {
        font-size: 1.5rem; font-weight: 700; margin: 0 0 0.15rem; line-height: 1.3;
      }
      .artwork-master-name a {
        color: inherit; text-decoration: none; border-bottom: 2px solid transparent;
        transition: border-color 0.2s;
      }
      .artwork-master-name a:hover { border-bottom-color: #c0392b; }
      .artwork-detail-title {
        font-size: 1.2rem; font-style: italic; color: rgb(96, 115, 159);
        margin: 0 0 0.25rem; font-weight: 400;
      }
      .artwork-detail-year {
        font-size: 1rem; color: rgb(96, 115, 159); margin: 0;
      }
      .artwork-description {
        font-size: 1.05rem; line-height: 1.7; color: rgb(55, 65, 81);
        margin-bottom: 2.5rem;
      }
      .meta-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 1.5rem 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgb(229, 233, 240);
      }
      .meta-item {}
      .meta-label {
        font-size: 0.78rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.08em; color: rgb(156, 163, 175); margin: 0 0 0.3rem;
      }
      .meta-value {
        font-size: 0.95rem; color: rgb(55, 65, 81); margin: 0; line-height: 1.4;
      }
      .element-tag {
        display: inline-block; background: rgb(243, 244, 246);
        padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.82rem;
        margin: 0.15rem 0.15rem 0 0; color: rgb(55, 65, 81);
      }
      .glightbox-clean .gslide-image img { 
        border-radius: 0 !important; 
      }
      /* Інші роботи майстра */
      .other-works {
        max-width: 960px;
        margin: 4rem auto 0;
        padding-top: 2.5rem;
        border-top: 1px solid rgb(229, 233, 240);
      }
      .other-works__header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 1.75rem;
      }
      .other-works__title {
        font-size: 1.25rem;
        font-weight: 600;
        color: rgb(55, 65, 81);
        margin: 0;
        line-height: 1.3;
      }
      .other-works__link {
        font-size: 0.875rem;
        color: #c0392b;
        text-decoration: none;
        white-space: nowrap;
        transition: opacity 0.15s;
      }
      .other-works__link:hover {
        opacity: 0.75;
      }
      .other-works__grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem 1.25rem;
        align-items: start;
      }
      .other-work-card {
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s ease;
      }
      .other-work-card:hover {
        transform: translateY(-2px);
      }
      .other-work-card__img-wrap {
        background: rgb(229, 233, 240);
        margin-bottom: 0.6rem;
      }
      .other-work-card__img {
        width: 100% !important;
        height: auto !important;
        border-radius: 0 !important;
        display: block;
        transition: opacity 0.2s ease;
      }
      .other-work-card:hover .other-work-card__img {
        opacity: 0.82;
      }
      .other-work-card__title {
        font-size: 0.85rem;
        font-style: italic;
        color: rgb(96, 115, 159);
        margin: 0 0 0.1rem;
        line-height: 1.3;
      }
      .other-work-card__year {
        font-size: 0.78rem;
        color: rgb(96, 115, 159);
        margin: 0;
      }

      @media (max-width: 700px) {
        .other-works__grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 600px) {
        .meta-grid { grid-template-columns: 1fr; gap: 1.25rem; }
      }
      .gclose { display: flex !important; }
      .glightbox-clean .gclose { top: 15px; right: 15px; }
    </style>
    <style is:global>
      .gslide-image img,
      .glightbox-container .gslide-image img {
        border-radius: 0 !important;
      }
      .pswp__img,
      .pswp .pswp__zoom-wrap img {
        border-radius: 0 !important;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div style="max-width: 720px; margin: 0 auto;">
        <a href={locale === 'en' ? '/en/gallery' : '/gallery'} class="back-link" id="back-link">{labels.back}</a>
      </div>

      <div class="artwork-hero" id="pswp-gallery">
        <a
          href={fullSize.src}
          data-pswp-width={Math.min(3200, sourceWidth)}
          data-pswp-height={Math.round(Math.min(3200, sourceWidth) * (sourceHeight / sourceWidth))}
          class="pswp-link"
          target="_blank"
          rel="noopener"
        >
          <Image
            id="artwork-main-img"
            src={artwork.data.image}
            alt={artwork.data.title}
            widths={[720, 1200, 1800, 2400, 3200]}
            sizes="(max-width: 720px) 100vw, 720px"
            quality={95}
            format="webp"
            style="cursor: zoom-in; width: 100%; height: auto;"
          />
        </a>
      </div>

      <div class="artwork-details">
        <div class="artwork-header">
          <p class="artwork-master-name">
            {masterUrl
              ? <a href={masterUrl}>{artwork.data.master}</a>
              : artwork.data.master
            }
          </p>
          <p class="artwork-detail-title">{artwork.data.title}</p>
          {artwork.data.year && <p class="artwork-detail-year">{artwork.data.year}</p>}
        </div>

        {artwork.data.description && (
          <p class="artwork-description">{artwork.data.description}</p>
        )}

        {(artwork.data.medium || artwork.data.dimensions || artwork.data.location || (artwork.data.elements && artwork.data.elements.length > 0)) && (
          <div class="meta-grid">
            {artwork.data.medium && (
              <div class="meta-item">
                <p class="meta-label">{labels.materials}</p>
                <p class="meta-value">{artwork.data.medium}</p>
              </div>
            )}
            {artwork.data.dimensions && (
              <div class="meta-item">
                <p class="meta-label">{labels.dimensions}</p>
                <p class="meta-value">{artwork.data.dimensions}</p>
              </div>
            )}
            {artwork.data.location && (
              <div class="meta-item">
                <p class="meta-label">{labels.location}</p>
                <p class="meta-value">
                  {locationUrl
                    ? <a href={locationUrl} style="color: #c0392b; text-decoration: none; border-bottom: 1px solid #f5c6c0;">{artwork.data.location}</a>
                    : artwork.data.location
                  }
                </p>
              </div>
            )}
            {artwork.data.elements && artwork.data.elements.length > 0 && (
              <div class="meta-item">
                <p class="meta-label">{labels.elements}</p>
                <div>
                  {artwork.data.elements.map(el => (
                    <span class="element-tag">{el}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </div>

      {otherWorksByMaster.length > 0 && (
        <section class="other-works">
          <div class="other-works__header">
            <h2 class="other-works__title">
              {locale === 'uk' 
                ? 'Інші роботи цього майстра' 
                : 'More works by this master'
              }
            </h2>
            <a href={galleryFilterUrl} class="other-works__link">
              {locale === 'uk' ? 'Усі роботи' : 'All works'} →
            </a>
          </div>
          <div class="other-works__grid">
            {otherWorksByMaster.map(work => (
              <a href={getContentUrl('gallery', work.id)} class="other-work-card">
                <div class="other-work-card__img-wrap">
                  <Image
                    src={work.data.image}
                    alt={work.data.title}
                    widths={[300, 500, 700]}
                    sizes="(max-width: 600px) 50vw, 25vw"
                    quality={88}
                    format="webp"
                    class="other-work-card__img"
                  />
                </div>
                <p class="other-work-card__title">{work.data.title}</p>
                {work.data.year && <p class="other-work-card__year">{work.data.year}</p>}
              </a>
            ))}
          </div>
        </section>
      )}

      <div style="max-width: 720px; margin: 3rem auto 0; padding: 2rem 0 0; border-top: 1px solid rgb(229, 233, 240);">
        <p style="font-size: 0.8rem; color: rgb(156, 163, 175); line-height: 1.6; margin: 0;">
          {locale === 'uk'
            ? <>Авторські права на цей твір належать правовласнику. Зображення представлено виключно з метою ознайомлення та популяризації петриківського розпису і не може бути використане в комерційних цілях без дозволу правовласника. Місце зберігання чи власник твору вказані в описі картини. В разі уточнень чи додаткової інформації ви можете звернутися за вказаними <a href="/contacts" style="color: rgb(156, 163, 175); border-bottom: 1px solid rgb(200, 205, 215);">контактами</a>.</>
            : <>Copyright for this work belongs to the rights holder. The image is presented solely for educational purposes and promotion of Petrykivka painting and may not be used for commercial purposes without permission from the rights holder. The storage location or owner of the work is indicated in the artwork description. For clarifications or additional information, please reach out via our <a href="/en/contacts" style="color: rgb(156, 163, 175); border-bottom: 1px solid rgb(200, 205, 215);">contacts</a>.</>
          }
        </p>
      </div>
    </main>
    <Footer />
    <script type="module">
      import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe-lightbox.esm.js';

      const lightbox = new PhotoSwipeLightbox({
        gallery: '#pswp-gallery',
        children: 'a.pswp-link',
        pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.esm.js'),
        wheelToZoom: true,
        initialZoomLevel: 'fit',
        secondaryZoomLevel: 1.5,
        maxZoomLevel: 4,
        bgOpacity: 0.95,
      });
      lightbox.init();
    </script>

    <script is:inline>
      var backLink = document.getElementById('back-link');
      if (backLink) {
        try {
          var params = new URLSearchParams(window.location.search);
          var from = params.get('from');
          if (from) {
            var baseHref = backLink.getAttribute('href').split('?')[0];
            backLink.setAttribute('href', baseHref + '?' + decodeURIComponent(from));
          }
        } catch(e) {}
      }
    </script>
  </body>
</html>