---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import { getLocaleFromUrl, t } from '../../../i18n/translations';
import { getSlugFromId, getContentUrl, filterByLocale } from '../../../i18n/content';

export async function getStaticPaths() {
  const allMasters = await getCollection('masters');
  const enMasters = allMasters.filter(m => m.id.startsWith('en/'));
  return enMasters.map(master => ({
    params: { id: master.id.replace('en/', '') },
    props: { master, allMasters },
  }));
}

const { master, allMasters } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const localeMasters = filterByLocale(allMasters, locale);
const { Content } = await render(master);

function getMasterUrl(name) {
  const found = localeMasters.find(m => m.data.name === name);
  return found ? getContentUrl('masters', found.id) : null;
}

const resolvedTagGroups = [
  { label: 'Center', values: master.data.center ? [master.data.center] : [], type: 'tag' },
  { label: 'Period', values: master.data.period ? [master.data.period] : [], type: 'tag' },
  { label: 'School', values: master.data.school || [], type: 'tag' },
  { label: 'Teachers', values: master.data.teachers || [], type: 'master' },
  { label: 'Influenced', values: master.data.influenced || [], type: 'master' },
].map(group => ({
  ...group,
  items: group.values.map(value => ({
    value,
    url: group.type === 'master' ? (getMasterUrl(value) || '/en/masters/tags/' + value.toLowerCase().replace(/ /g, '-')) : '/en/masters/tags/' + value.toLowerCase().replace(/ /g, '-'),
    isMaster: group.type === 'master' && getMasterUrl(value) !== null,
  })),
}));

const allBooks = await getCollection('books');
const localBooks = filterByLocale(allBooks, locale);
const masterBooks = localBooks.filter(book =>
  book.data.masters && book.data.masters.includes(master.data.name)
);
const allArtworks = await getCollection('artworks');
const masterArtworks = filterByLocale(allArtworks, locale).filter(
  a => a.data.master === master.data.name
);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={master.data.name} description={master.data.name} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/css/glightbox.min.css" />
    <style>
      .master-page h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        line-height: 1.25;
      }
      .master-page .master-category {
        font-size: 0.78rem;
        color: #c0392b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
      }
      .master-page .master-dates {
        font-size: 0.9rem;
        color: rgb(96, 115, 159);
        margin: 0 0 1.5rem;
      }
      .master-page .master-content {
        font-size: 1rem;
        line-height: 1.75;
      }
      .master-page .master-content h2 {
        font-size: 1.3rem;
        font-weight: 700;
        margin: 2rem 0 0.75rem;
      }
      .master-page .master-content h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 1.5rem 0 0.5rem;
      }
      .master-page .master-content p {
        margin: 0 0 1rem;
      }
      .tag-link {
        display: inline-block;
        background: #f0f0f0;
        padding: 2px 8px;
        border-radius: 12px;
        margin: 2px;
        text-decoration: none;
        color: inherit;
        font-size: 0.82rem;
      }
      .master-link {
        display: inline-block;
        background: #fff0ee;
        padding: 2px 8px;
        border-radius: 12px;
        margin: 2px;
        text-decoration: none;
        color: #c0392b;
        border: 1px solid #f5c6c0;
        font-size: 0.82rem;
      }
      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
      figcaption {
        font-size: 0.78rem;
        color: rgb(96,115,159);
        padding: 0.3rem 0;
        text-align: center;
      }
      .meta-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(229,233,240);
      }
      .meta-row {
        margin-bottom: 0.5rem;
        font-size: 0.88rem;
      }
      .meta-row strong {
        color: rgb(50, 55, 65);
        font-weight: 600;
      }
      .books-section {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(229,233,240);
      }
      .books-section h2 {
        font-size: 1.1rem;
        margin-bottom: 1rem;
      }
      .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }
      .book-card {
        text-decoration: none;
        color: inherit;
        display: block;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgb(229,233,240);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .book-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        border-color: transparent;
      }
      .book-cover-placeholder {
        width: 100%;
        height: 200px;
        background: rgb(229,233,240);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
      }
      .book-info {
        padding: 0.75rem;
      }
      .book-title {
        font-size: 0.85rem;
        font-weight: 700;
        margin: 0 0 0.25rem;
        line-height: 1.3;
      }
      .book-author {
        font-size: 0.78rem;
        color: rgb(96,115,159);
        margin: 0;
      }
      .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        color: rgb(96, 115, 159);
        text-decoration: none;
        font-size: 0.9rem;
      }
      .back-link:hover { color: #c0392b; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href={backUrl} class="back-link" id="back-link">{backLabel}</a>

      <div class="master-page">
        <h1>{master.data.name}</h1>

        {master.data.photo && (
          <div style="margin: 0 0 2rem;">
            <Image
              src={master.data.photo}
              alt={master.data.name}
              width={800}
              height={500}
              style="width: 100%; max-width: 800px; height: auto; display: block; border-radius: 0;"
            />
          </div>
        )}

        <div class="master-content">
          <Content />
        </div>

      {masterArtworks.length > 0 && (
        <section style="margin-top: 2rem;">
          <h2>{locale === 'uk' ? 'Роботи' : 'Works'}</h2>
          <div class="gallery-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
            {masterArtworks.map(artwork => (
              <a href={getContentUrl('gallery', artwork.id)} style="text-decoration: none; color: inherit; display: block;">
                <figure style="margin: 0;">
                  <Image
                    src={artwork.data.image}
                    alt={artwork.data.title}
                    widths={[300]}
                    sizes="33vw"
                    style="width: 100%; height: auto; display: block; border-radius: 0;"
                  />
                  <figcaption style="font-size: 0.8rem; color: rgb(96,115,159); padding: 0.4rem 0;">
                    {artwork.data.title}{artwork.data.year ? `, ${artwork.data.year}` : ''}
                  </figcaption>
                </figure>
              </a>
            ))}
          </div>
        </section>
      )}
      
      {master.data.links && master.data.links.length > 0 && (
        <section style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgb(229,233,240);">
          <h2 style="font-size: 1.2rem; margin-bottom: 1rem;">{locale === 'uk' ? 'Посилання' : 'Links'}</h2>
          <ul style="list-style: none; padding: 0; margin: 0;">
            {master.data.links.map(link => (
              <li style="margin-bottom: 0.5rem;">
                <a href={link.url} target="_blank" rel="noopener" style="color: #c0392b; text-decoration: none; border-bottom: 1px solid #f5c6c0; font-size: 0.95rem;">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="meta-section">
        {resolvedTagGroups.map(group => group.items.length > 0 && (
          <div class="meta-row">
            <strong>{group.label}:</strong>{' '}
            {group.items.map(item => (
              <a href={item.url} class={item.isMaster ? 'master-link' : 'tag-link'}>
                {item.value}
              </a>
            ))}
          </div>
        ))}
        <div class="meta-row">
          <strong>Category:</strong> {master.data.category}
        </div>
      </section>

      {masterBooks.length > 0 && (
        <section class="books-section">
          <h2>Additional Materials</h2>
          <div class="books-grid">
            {masterBooks.map(book => (
              <a href={getContentUrl('books', book.id)} class="book-card">
                {book.data.cover
                  ? (
                    <Image
                      src={book.data.cover}
                      alt={book.data.title}
                      width={160}
                      height={200}
                      style="width: 100%; height: 200px; object-fit: cover; display: block;"
                    />
                  ) : (
                    <div class="book-cover-placeholder">📖</div>
                  )
                }
                <div class="book-info">
                  <p class="book-title">{book.data.title}</p>
                  {book.data.author && (
                    <p class="book-author">{book.data.author}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
      </div>
    </main>
    <Footer />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/js/glightbox.min.js"></script>
    <script>
      const lightbox = GLightbox({ selector: '.glightbox' });
    </script>
    <script is:inline>
      // Restore scroll position via back link
      var backLink = document.getElementById('back-link');
      if (backLink) {
        var ref = document.referrer;
        if (ref && ref.includes('/masters')) {
          backLink.addEventListener('click', function(e) {
            e.preventDefault();
            history.back();
          });
        }
      }
    </script>
  </body>
</html>