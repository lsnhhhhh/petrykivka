      .hist-page {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 0 24px;
      }

      .hist-layout {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 56px;
        align-items: start;
      }

      .hist-toc {
        position: sticky;
        top: 32px;
      }
      .hist-toc-inner {
