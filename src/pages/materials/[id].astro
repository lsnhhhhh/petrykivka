---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allMaterials = await getCollection('materials');
  return allMaterials.map(material => ({
    params: { id: material.id },
    props: { material },
  }));
}

const { material } = Astro.props;
const { Content } = await render(material);

const allMasters = await getCollection('masters');
function getMasterUrl(name) {
  const found = allMasters.find(m => m.data.name === name);
  return found ? '/masters/' + found.id : '/masters';
}

const isGallery = material.data.category === 'Галереї';
const isVideo = material.data.category === 'Відео';
const isLongread = material.data.category === 'Лонгріди';
const isMasterclass = material.data.category === 'Майстер-класи';
---
<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title={material.data.title} description={material.data.description || material.data.title} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/css/glightbox.min.css" />
    <style is:global>
      .material-page main {
        max-width: 100%;
        width: 100%;
        padding: 3em 0;
      }
      .material-page .inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1em;
      }
      .material-page .inner-wide {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 1em;
      }
      .material-category {
        font-size: 0.85rem;
        color: #c0392b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
      }
      .material-title {
        font-size: 2.2rem;
        font-weight: 700;
        margin: 0 0 1.5rem;
        line-height: 1.2;
      }
      .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        color: rgb(96, 115, 159);
        text-decoration: none;
        font-size: 0.95rem;
      }
      .back-link:hover { color: #c0392b; }
      .master-link {
        display: inline-block;
        background: #fff0ee;
        padding: 2px 10px;
        border-radius: 12px;
        margin: 2px;
        text-decoration: none;
        color: #c0392b;
        border: 1px solid #f5c6c0;
        font-size: 0.9rem;
      }
      .meta-row {
        font-size: 0.9rem;
        color: rgb(96, 115, 159);
        margin-bottom: 1rem;
      }
      .meta-row strong { color: #000; }
      .video-embed {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 8px;
        margin-bottom: 1.5rem;
      }
      .video-embed iframe {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        border: 0;
      }
      .gallery-content img {
        width: min(1080px, 100vw);
        max-width: min(1080px, 100vw);
        margin-left: max(calc(-540px + 50%), calc(-50vw + 50%));
        height: auto;
        display: block;
        margin-bottom: 0.5rem;
        border-radius: 0;
      }
      .gallery-content h1,
      .gallery-content h2,
      .gallery-content h3 {
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
        padding: 0 1em;
      }
      .gallery-content p {
        max-width: 720px;
        margin: 0 auto 1.5rem;
        padding: 0 1em;
        font-size: 0.85rem;
        color: rgb(96, 115, 159);
      }
      .longread-content {
        font-size: 1.1rem;
        line-height: 1.8;
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1em;
      }
      .longread-content img {
        width: min(1080px, 100vw);
        max-width: min(1080px, 100vw);
        margin-left: max(calc(-540px + 50%), calc(-50vw + 50%));
        height: auto;
        display: block;
        margin: 1.5rem 0;
        border-radius: 0;
      }
      .masterclass-content {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1em;
      }
      .masterclass-content h2 {
        border-left: 4px solid #c0392b;
        padding-left: 1rem;
        margin-top: 2rem;
      }
      .masterclass-content img {
        width: min(1080px, 100vw);
        max-width: min(1080px, 100vw);
        margin-left: max(calc(-540px + 50%), calc(-50vw + 50%));
        height: auto;
        display: block;
        margin: 1rem 0;
        border-radius: 0;
      }
    </style>
  </head>
  <body class="material-page">
    <Header />
    <main>
      <div class="inner">
        <a href="/materials" class="back-link">← Всі матеріали</a>
        <p class="material-category">{material.data.category}</p>
        <h1 class="material-title">{material.data.title}</h1>
        {material.data.masters && material.data.masters.length > 0 && (
          <div class="meta-row">
            <strong>Майстри:</strong>{' '}
            {material.data.masters.map(name => (
              <a href={getMasterUrl(name)} class="master-link">
                {name}
              </a>
            ))}
          </div>
        )}
      </div>

      {isVideo && material.data.videoUrl && (
        <div class="inner-wide">
          <div class="video-embed">
            <iframe
              src={material.data.videoUrl.replace('watch?v=', 'embed/')}
              allowfullscreen
            ></iframe>
          </div>
        </div>
      )}

      {isGallery && (
        <div class="gallery-content">
          <Content />
        </div>
      )}

      {isLongread && (
        <div class="longread-content">
          <Content />
        </div>
      )}

      {isMasterclass && (
        <div class="masterclass-content">
          <Content />
        </div>
      )}

      {isVideo && (
        <div class="inner">
          <Content />
        </div>
      )}
    </main>
    <Footer />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/js/glightbox.min.js"></script>
    <script is:inline>
      const lightbox = GLightbox({ selector: '.glightbox' });
    </script>
  </body>
</html>