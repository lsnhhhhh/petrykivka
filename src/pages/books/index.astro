---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allBooks = await getCollection('books');

const categories = [
  'Альбоми',
  'Альбоми про майстрів',
  'Мистецтвознавчі дослідження',
  'Оздоблені розписом',
  'Наукові статті',
  'Інше',
];

const booksByCategory = categories.map(category => ({
  category,
  books: allBooks.filter(b => b.data.category === category),
})).filter(group => group.books.length > 0);
---
<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title="Книги" description="Бібліотека книг про петриківський розпис" />
    <style>
      h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      .subtitle {
        color: rgb(96, 115, 159);
        font-size: 1.1rem;
        margin-bottom: 2rem;
      }
      .nav-anchors {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 3rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgb(229, 233, 240);
      }
      .nav-anchors a {
        text-decoration: none;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        border: 1px solid rgb(229, 233, 240);
        color: rgb(0, 0, 0);
        transition: all 0.2s;
      }
      .nav-anchors a:hover {
        border-color: #c0392b;
        color: #c0392b;
      }
      .category-section {
        margin-bottom: 4rem;
      }
      .category-section h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #c0392b;
        display: inline-block;
      }
      .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
      }
      .book-card {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgb(229, 233, 240);
        text-decoration: none;
        color: inherit;
        display: block;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .book-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        border-color: transparent;
      }
      .book-cover {
        width: 100%;
        height: 280px;
        object-fit: cover;
        display: block;
      }
      .book-cover-placeholder {
        width: 100%;
        height: 280px;
        background: rgb(229, 233, 240);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
      }
      .book-info {
        padding: 1rem 1.25rem 1.25rem;
      }
      .book-title {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.3rem;
        line-height: 1.3;
      }
      .book-author {
        font-size: 0.85rem;
        color: rgb(96, 115, 159);
        margin: 0 0 0.2rem;
      }
      .book-year {
        font-size: 0.8rem;
        color: rgb(96, 115, 159);
        margin: 0;
      }
      .book-links {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.75rem;
        flex-wrap: wrap;
      }
      .book-link {
        font-size: 0.8rem;
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        text-decoration: none;
        border: 1px solid rgb(229, 233, 240);
        color: inherit;
        transition: all 0.2s;
      }
      .book-link:hover {
        border-color: #c0392b;
        color: #c0392b;
      }
      .book-link.pdf {
        background: #fff0ee;
        border-color: #f5c6c0;
        color: #c0392b;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Книги</h1>
      <p class="subtitle">Бібліотека видань про петриківський розпис</p>

      <nav class="nav-anchors">
        {booksByCategory.map(group => (
          <a href={'#' + group.category.toLowerCase().replace(/ /g, '-')}>
            {group.category}
          </a>
        ))}
      </nav>

      {booksByCategory.map(group => (
        <section
          class="category-section"
          id={group.category.toLowerCase().replace(/ /g, '-')}
        >
          <h2>{group.category}</h2>
          <div class="books-grid">
            {group.books.map(book => (
              <a href={'/books/' + book.id} class="book-card">
                {book.data.cover
                  ? (
                    <Image
                      src={book.data.cover}
                      alt={book.data.title}
                      width={200}
                      height={280}
                      class="book-cover"
                    />
                  ) : (
                    <div class="book-cover-placeholder">📖</div>
                  )
                }
                <div class="book-info">
                  <p class="book-title">{book.data.title}</p>
                  {book.data.author && (
                    <p class="book-author">{book.data.author}</p>
                  )}
                  {book.data.year && (
                    <p class="book-year">{book.data.year}</p>
                  )}
                  <div class="book-links">
                    {book.data.externalUrl && (
                      <span class="book-link">Читати онлайн</span>
                    )}
                    {book.data.pdfUrl && (
                      <span class="book-link pdf">PDF</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>
    <Footer />
  </body>
</html>