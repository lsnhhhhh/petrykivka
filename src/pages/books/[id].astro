---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const allBooks = await getCollection('books');
  return allBooks.map(book => ({
    params: { id: book.id },
    props: { book },
  }));
}

const { book } = Astro.props;
const { Content } = await render(book);

const allMasters = await getCollection('masters');

function getMasterUrl(name) {
  const found = allMasters.find(m => m.data.name === name);
  return found ? '/masters/' + found.id : null;
}
---
<!doctype html>
<html lang="uk">
  <head>
    <BaseHead title={book.data.title} description={book.data.title} />
    <style>
      .book-header {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
      }
      .book-cover {
        border-radius: 8px;
        width: 100%;
        height: auto;
        display: block;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
      }
      .book-cover-placeholder {
        width: 220px;
        height: 300px;
        background: rgb(229, 233, 240);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 5rem;
      }
      .book-meta {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .book-meta p {
        margin: 0;
        padding: 0;
      }
      .book-meta h1 {
        margin: 0 0 0.5rem;
      }
      .meta-row {
        font-size: 0.95rem;
        color: rgb(96, 115, 159);
         margin-bottom: 0.4rem;
         padding: 0;
      }
      .meta-row strong {
        color: rgb(0, 0, 0);
      }
      .book-links {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
        flex-wrap: wrap;
      }
      .book-link {
        padding: 0.6rem 1.75rem;
        border-radius: 30px;
        text-decoration: none;
        font-size: 1 rem;
        border: 2px solid #c0392b;
        color: #c0392b;
        font-weight: 500;
        transition: all 0.2s;
      }
      .book-link:hover {
        background: #c0392b;
        color: white;
        border-color: #c0392b;
      }
      .book-link.pdf {
        background: #fff0ee;
        border-color: #f5c6c0;
        color: #c0392b;
      }
      .master-link {
        display: inline-block;
        background: #fff0ee;
        padding: 2px 10px;
        border-radius: 12px;
        margin: 2px;
        text-decoration: none;
        color: #c0392b;
        border: 1px solid #f5c6c0;
        font-size: 0.9rem;
      }
      .section-divider {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(229, 233, 240);
      }
      @media (max-width: 600px) {
        .book-header {
          grid-template-columns: 1fr;
        }
        .book-cover-placeholder {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href="/books">← Всі книги</a>

      <div class="book-header">
        {book.data.cover
          ? (
            <Image
              src={book.data.cover}
              alt={book.data.title}
              width={220}
              height={300}
              class="book-cover"
            />
          ) : (
            <div class="book-cover-placeholder">📖</div>
          )
        }
        <div class="book-meta">
          <h1>{book.data.title}</h1>
          {book.data.author && (
            <p class="meta-row"><strong>Автор:</strong> {book.data.author}</p>
          )}
          {book.data.year && (
            <p class="meta-row"><strong>Рік:</strong> {book.data.year}</p>
          )}
          {book.data.publisher && (
            <p class="meta-row"><strong>Видавництво:</strong> {book.data.publisher}</p>
          )}
          {book.data.language && (
  <p class="meta-row">
    <strong>Мова:</strong>{' '}
    {Array.isArray(book.data.language)
      ? book.data.language.join(', ')
      : book.data.language}
  </p>
          )}
          <p class="meta-row"><strong>Категорія:</strong> {book.data.category}</p>
          {book.data.masters && book.data.masters.length > 0 && (
            <div class="meta-row">
              <strong>Майстри:</strong>{' '}
              {book.data.masters.map(name => (
                <a href={getMasterUrl(name) || '/masters'} class="master-link">
                  {name}
                </a>
              ))}
            </div>
          )}
          <div class="book-links">
            {book.data.externalUrl && (
              <a href={book.data.externalUrl} target="_blank" class="book-link">
                Читати онлайн
              </a>
            )}
            {book.data.pdfUrl && (
              <a href={book.data.pdfUrl} target="_blank" class="book-link pdf">
                Завантажити PDF
              </a>
            )}
          </div>
        </div>
      </div>

      <div class="section-divider">
        <Content />
      </div>
    </main>
    <Footer />
  </body>
</html>